.context/

# /cj_goal_feature resume-state scratch (never committed)
.cj-goal-feature/

# /cj_goal_task resume-state scratch (never committed)
.cj-goal-task/

# cj_goal local-E2E sandbox marker (F000071 Part A) — the second half of the
# build-gate auto-answer seam's double guard. NEVER tracked: it only ever exists
# in a throwaway sandbox checkout; validate.sh Check 29 hard-fails if it appears
# in the tracked tree.
.cj-e2e-sandbox

# cj_goal local-E2E run reports (F000071 Part B) — per-run artifacts written by
# scripts/e2e-local.sh. They are NOT tracked, except the committed EXAMPLE.md
# sample (so the report format is reviewable in a PR).
tests/e2e-local/reports/*
!tests/e2e-local/reports/EXAMPLE.md
