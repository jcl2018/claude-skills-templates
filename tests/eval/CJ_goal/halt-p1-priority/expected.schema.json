{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "halt-p1-priority expected output",
  "description": "Asserts that /CJ_goal halts a P1-priority TODO at preflight with a reason mentioning P1.",
  "type": "object",
  "required": ["halt_class", "halt_reason_contains"],
  "additionalProperties": true,
  "properties": {
    "halt_class": {
      "type": "string",
      "const": "halted_at_preflight"
    },
    "halt_reason_contains": {
      "type": "string",
      "pattern": "P1|priority"
    }
  }
}
