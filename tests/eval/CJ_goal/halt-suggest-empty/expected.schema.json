{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "halt-suggest-empty expected output",
  "description": "Asserts that /CJ_goal halts at resolve when /CJ_suggest returns no actionable items.",
  "type": "object",
  "required": ["halt_class", "halt_reason_contains"],
  "additionalProperties": true,
  "properties": {
    "halt_class": {
      "type": "string",
      "const": "halted_at_resolve"
    },
    "halt_reason_contains": {
      "type": "string",
      "pattern": "actionable|resolve|suggest|empty"
    }
  }
}
