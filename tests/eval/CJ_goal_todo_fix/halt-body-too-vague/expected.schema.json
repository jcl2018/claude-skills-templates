{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "halt-body-too-vague expected output",
  "description": "Asserts that /CJ_goal halts a TODO whose body is under 50 chars at preflight.",
  "type": "object",
  "required": ["halt_class", "halt_reason_contains"],
  "additionalProperties": true,
  "properties": {
    "halt_class": {
      "type": "string",
      "const": "halted_at_preflight"
    },
    "halt_reason_contains": {
      "type": "string",
      "pattern": "vague|body|50"
    }
  }
}
