{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "halt-design-keyword expected output",
  "description": "Asserts that /CJ_goal_todo_fix halts a TODO whose body contains a design-needed keyword.",
  "type": "object",
  "required": ["halt_class", "halt_reason_contains"],
  "additionalProperties": true,
  "properties": {
    "halt_class": {
      "type": "string",
      "const": "halted_at_preflight"
    },
    "halt_reason_contains": {
      "type": "string",
      "pattern": "design|investigate|spike|unclear|figure out|TBD"
    }
  }
}
