{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "halt-size-large expected output",
  "description": "Asserts that /CJ_goal_todo_fix halts a size-L TODO at preflight with a reason mentioning size or L.",
  "type": "object",
  "required": ["halt_class", "halt_reason_contains"],
  "additionalProperties": true,
  "properties": {
    "halt_class": {
      "type": "string",
      "const": "halted_at_preflight"
    },
    "halt_reason_contains": {
      "type": "string",
      "pattern": "size|L|XL"
    }
  }
}
