      "const": 3
    },
    "drained_count": {
      "type": "integer",
      "const": 3
    },
    "drained_pr_urls_length": {
      "type": "integer",
      "const": 3
    },
    "auq_recommendation": {
      "type": "string",
      "const": "yes"
    },
    "end_state": {
      "type": "string",
      "const": "drained_complete"
