{
  "version": "2.0.0",
  "description": "Declarative artifact definitions per work item type. Read by /work-track during scaffolding. v2: type-specific tracker templates, new artifact types.",
  "types": {
    "feature": {
      "required": [
        {"artifact": "tracker", "template": "tracker-feature.md", "filename": "TRACKER.md"},
        {"artifact": "prd", "template": "doc-PRD.md", "filename": "PRD.md"},
        {"artifact": "architecture", "template": "doc-ARCHITECTURE.md", "filename": "ARCHITECTURE.md"},
        {"artifact": "test-spec", "template": "doc-TEST-SPEC.md", "filename": "TEST-SPEC.md"},
        {"artifact": "milestones", "template": "doc-milestones.md", "filename": "milestones.md"}
      ],
      "optional": [],
      "lifecycle_overrides": {}
    },
    "defect": {
      "required": [
        {"artifact": "tracker", "template": "tracker-defect.md", "filename": "TRACKER.md"},
        {"artifact": "rca", "template": "doc-RCA.md", "filename": "RCA.md"},
        {"artifact": "test-plan", "template": "doc-test-plan.md", "filename": "test-plan.md"}
      ],
      "optional": [],
      "lifecycle_overrides": {}
    },
    "task": {
      "required": [
        {"artifact": "tracker", "template": "tracker-task.md", "filename": "TRACKER.md"},
        {"artifact": "test-plan", "template": "doc-test-plan.md", "filename": "test-plan.md"}
      ],
      "optional": [],
      "lifecycle_overrides": {}
    },
    "user-story": {
      "required": [
        {"artifact": "tracker", "template": "tracker-user-story.md", "filename": "TRACKER.md"},
        {"artifact": "prd", "template": "doc-PRD.md", "filename": "PRD.md"},
        {"artifact": "architecture", "template": "doc-ARCHITECTURE.md", "filename": "ARCHITECTURE.md"},
        {"artifact": "test-spec", "template": "doc-TEST-SPEC.md", "filename": "TEST-SPEC.md"},
        {"artifact": "milestones", "template": "doc-milestones.md", "filename": "milestones.md"}
      ],
      "optional": [],
      "lifecycle_overrides": {}
    }
  },
  "template_dir": "~/.claude/spec/templates",
  "work_items_dir": "./work-items"
}
