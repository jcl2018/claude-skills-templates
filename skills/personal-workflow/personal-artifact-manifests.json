{
  "version": "3.0.0",
  "description": "Personal work item type-to-artifact mapping. Read by personal-workflow check (directory mode).",
  "types": {
    "feature": {
      "required": [
        {"artifact": "tracker", "template": "tracker-feature.md", "filename": "TRACKER.md"},
        {"artifact": "design", "template": "doc-DESIGN.md", "filename": "DESIGN.md"},
        {"artifact": "roadmap", "template": "doc-ROADMAP.md", "filename": "ROADMAP.md"}
      ],
      "optional": [],
      "lifecycle_overrides": {}
    },
    "defect": {
      "required": [
        {"artifact": "tracker", "template": "tracker-defect.md", "filename": "TRACKER.md"},
        {"artifact": "rca", "template": "doc-RCA.md", "filename": "RCA.md"},
        {"artifact": "test-plan", "template": "doc-test-plan.md", "filename": "test-plan.md"}
      ],
      "optional": [],
      "lifecycle_overrides": {}
    },
    "task": {
      "required": [
        {"artifact": "tracker", "template": "tracker-task.md", "filename": "TRACKER.md"},
        {"artifact": "test-plan", "template": "doc-test-plan.md", "filename": "test-plan.md"}
      ],
      "optional": [],
      "lifecycle_overrides": {}
    },
    "user-story": {
      "required": [
        {"artifact": "tracker", "template": "tracker-user-story.md", "filename": "TRACKER.md"},
        {"artifact": "design", "template": "doc-DESIGN.md", "filename": "DESIGN.md"},
        {"artifact": "spec", "template": "doc-SPEC.md", "filename": "SPEC.md"},
        {"artifact": "test-spec", "template": "doc-TEST-SPEC.md", "filename": "TEST-SPEC.md"}
      ],
      "optional": [],
      "lifecycle_overrides": {}
    }
  },
  "template_dir": "~/.claude/templates",
  "work_items_dir": "./work-items"
}
