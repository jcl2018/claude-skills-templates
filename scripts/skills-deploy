#!/usr/bin/env bash
# skills-deploy — install, remove, relink, and diagnose skills from this repo.
# Usage: skills-deploy <install|remove|relink|doctor> [options]
#   install [--bundle]   F000049/S2 install == clone: ensure a managed git checkout
#                        at ~/.claude/skills/cj-workbench (override SKILLS_DEPLOY_BUNDLE_TARGET)
#                        and symlink the flat /CJ_* skills INTO it. Opt-in; the default
#                        dev-clone install is untouched.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CATALOG="$REPO_ROOT/skills-catalog.json"
# Skills source root is catalog-driven (F000006). Each skill's source dir comes
# from dirname(.files[0]) via skill_source_dir(); skills can live anywhere in
# the repo as long as the catalog points at them.
SKILLS_TARGET="${SKILLS_DEPLOY_TARGET:-$HOME/.claude/skills}"
MANIFEST="${SKILLS_DEPLOY_MANIFEST:-$HOME/.claude/.skills-templates.json}"
TEMPLATES_SRC="$REPO_ROOT/templates"
TEMPLATES_TARGET="${SKILLS_DEPLOY_TEMPLATES_TARGET:-$HOME/.claude/templates}"
RULES_SRC="$REPO_ROOT/rules"
RULES_TARGET="${SKILLS_DEPLOY_RULES_TARGET:-$HOME/.claude/rules}"
# Shared scripts deposit (F000049 / S000085): the shared `scripts/*.sh` helpers
# (+ skills-update-check) travel with the install so the orchestrator-family
# skills resolve them bundle-first instead of reaching a separate source clone
# via `.source`. Deposited to a single `_cj-shared/scripts/` home; the scripts
# already resolve their OWN siblings dirname-relative (BASH_SOURCE), so a
# whole-set deposit keeps every transitive sibling co-located.
SHARED_SCRIPTS_SRC="$REPO_ROOT/scripts"
SHARED_SCRIPTS_TARGET="${SKILLS_DEPLOY_SHARED_SCRIPTS_TARGET:-$HOME/.claude/_cj-shared/scripts}"

# --- helpers ---

require_jq() {
  command -v jq >/dev/null 2>&1 || { echo "ERROR: jq is required" >&2; exit 1; }
}

# Strip CRLF from jq output on Windows (jq.exe writes \r\n). No-op on Unix.
jq() { command jq "$@" | tr -d '\r'; }

manifest_read() {
  [ -f "$MANIFEST" ] && cat "$MANIFEST" || echo '{}'
}

manifest_write() {
  local tmp
  tmp=$(mktemp "${MANIFEST}.tmp.XXXXXX")
  cat > "$tmp"
  mv "$tmp" "$MANIFEST"
}

# List all installable entries: every catalog entry, in catalog order. Catalog
# is the source of truth. Templates-only entries (empty files) are included;
# the install loop handles that branch.
discover_skills() {
  [ -f "$CATALOG" ] || return 0
  jq -r '.[].name' "$CATALOG" 2>/dev/null || true
}

# Read skill dependencies from catalog
skill_deps() {
  local name="$1"
  [ -f "$CATALOG" ] || return 0
  jq -r --arg n "$name" '.[] | select(.name == $n) | .depends.skills // [] | .[]' "$CATALOG" 2>/dev/null || true
}

# Read skill status from catalog (active|experimental). Missing = active.
skill_status() {
  local name="$1"
  [ -f "$CATALOG" ] || { echo "active"; return 0; }
  local s
  s=$(jq -r --arg n "$name" '.[] | select(.name == $n) | .status // "active"' "$CATALOG" 2>/dev/null || echo "active")
  [ -n "$s" ] || s="active"
  echo "$s"
}

# Check who owns a skill directory
skill_owner() {
  local name="$1"
  local target="$SKILLS_TARGET/$name/SKILL.md"
  if [ ! -e "$SKILLS_TARGET/$name" ]; then
    echo "none"
  elif [ -L "$target" ]; then
    local link
    link=$(readlink "$target" 2>/dev/null || true)
    case "$link" in
      */skills/gstack/*) echo "gstack" ;;
      "$REPO_ROOT"/*|"$HOME/.claude/skills-templates/"*) echo "ours" ;;
      *) echo "other" ;;
    esac
  else
    echo "manual"
  fi
}

# Reverse dependencies: skills that depend on $1
reverse_deps() {
  local name="$1"
  [ -f "$CATALOG" ] || return 0
  jq -r --arg n "$name" '.[] | select(.depends.skills // [] | index($n)) | .name' "$CATALOG" 2>/dev/null || true
}

# Read templates array for a skill from catalog
skill_templates() {
  local name="$1"
  [ -f "$CATALOG" ] || return 0
  jq -r --arg n "$name" '.[] | select(.name == $n) | .templates // [] | .[]' "$CATALOG" 2>/dev/null || true
}

# Catalog-driven path helpers (F000006). Source root and SKILL.md path come from
# the catalog's files[] array, not hardcoded skills/{name}/. Lets a skill live
# anywhere in the repo as long as the catalog points at it. files[0] is the
# SKILL.md by convention.

# SKILL.md path for a skill (repo-relative). Empty string if skill has no files.
skill_md_path() {
  local name="$1"
  [ -f "$CATALOG" ] || return 0
  jq -r --arg n "$name" '.[] | select(.name == $n) | (.files // []) | .[0] // ""' "$CATALOG" 2>/dev/null || true
}

# Absolute source directory for a skill: dirname of repo-relative files[0].
# Empty string if skill has no files (templates-only entries).
skill_source_dir() {
  local name="$1" f0
  f0=$(skill_md_path "$name")
  if [ -n "$f0" ]; then
    echo "$REPO_ROOT/$(dirname "$f0")"
  fi
}

# Templates source directory base for a skill (repo-relative). Defaults to
# "templates" so existing entries shaped "{skill}/x.md" resolve under
# templates/{skill}/x.md. Override via catalog templates_source field, used
# when the source lives outside templates/.
# When override is set, the entry's basename is joined with the override base.
skill_templates_source() {
  local name="$1"
  [ -f "$CATALOG" ] || { echo "templates"; return 0; }
  local s
  s=$(jq -r --arg n "$name" '.[] | select(.name == $n) | .templates_source // "templates"' "$CATALOG" 2>/dev/null || echo "templates")
  echo "${s:-templates}"
}

# SHA256 of a file (portable: macOS shasum, Linux sha256sum)
file_checksum() {
  (shasum -a 256 "$1" 2>/dev/null || sha256sum "$1" 2>/dev/null) | awk '{print $1}'
}

# Probe whether real symlinks work in $SKILLS_TARGET (S000079). On macOS/Linux/WSL2
# `ln -s` creates a true symlink; on Git Bash `ln -s` copies-by-default (or needs
# Developer Mode/admin), so the probe result drives the install mode. We probe in
# $SKILLS_TARGET itself (not /tmp) because the symlink capability is per-filesystem
# and the target may live on a different mount than $TMPDIR.
# Override: SKILLS_DEPLOY_FORCE_COPY=1 forces "no" (copy-mode) regardless of probe —
# used by tests to exercise copy-mode on a symlink-capable host.
# Echoes "yes" (real symlinks work) or "no" (use copy-mode). Never fails the script.
_can_symlink() {
  if [ "${SKILLS_DEPLOY_FORCE_COPY:-}" = "1" ]; then
    echo "no"
    return 0
  fi
  mkdir -p "$SKILLS_TARGET" 2>/dev/null || true
  local probe_src probe_link result="no"
  probe_src=$(mktemp "$SKILLS_TARGET/.symprobe.src.XXXXXX" 2>/dev/null) || { echo "no"; return 0; }
  probe_link="${probe_src}.lnk"
  rm -f "$probe_link" 2>/dev/null || true
  if ln -s "$probe_src" "$probe_link" 2>/dev/null && [ -L "$probe_link" ]; then
    result="yes"
  fi
  rm -f "$probe_src" "$probe_link" 2>/dev/null || true
  echo "$result"
}

# Validate template name is safe (no path traversal)
# Allows one subfolder level: "CJ_company-workflow/tracker-feature.md"
# Blocks ".." segments to prevent path traversal
validate_template_name() {
  if [[ "$1" =~ ^[a-zA-Z0-9_-]+(/[a-zA-Z0-9_.-]+)?\.md$ ]] && [[ "$1" != *".."* ]]; then
    return 0
  fi
  echo "  ERROR: unsafe template name: $1" >&2
  return 1
}

# --- install ---

# F000049 / S2 (S000086): bundle install (install == clone). Ensure a managed git
# checkout of the workbench at the bundle path, then delegate to its OWN
# skills-deploy install — that child's REPO_ROOT resolves to the bundle, so the
# flat /CJ_* skill dirs + _cj-shared scripts + templates symlink INTO the bundle
# (gstack's install==clone layout). Env overrides:
#   SKILLS_DEPLOY_BUNDLE_TARGET  bundle path (default ~/.claude/skills/cj-workbench)
#   SKILLS_DEPLOY_BUNDLE_SOURCE  clone source override (tests / offline)
# Clone source falls back to the manifest .source (a local git checkout), then
# upstream_url. Forwarded args ($@) reach the delegated install verbatim.
do_bundle_install() {
  require_jq
  local bundle="${SKILLS_DEPLOY_BUNDLE_TARGET:-$HOME/.claude/skills/cj-workbench}"

  # Resolve the clone source: explicit override > manifest .source (local git) > upstream_url.
  local src="${SKILLS_DEPLOY_BUNDLE_SOURCE:-}"
  if [ -z "$src" ]; then
    local m msrc murl
    m=$(manifest_read 2>/dev/null || echo '{}')
    msrc=$(echo "$m" | jq -r '.source // empty' 2>/dev/null)
    murl=$(echo "$m" | jq -r '.upstream_url // empty' 2>/dev/null)
    if [ -n "$msrc" ] && [ -d "$msrc/.git" ]; then
      src="$msrc"
    elif [ -n "$murl" ]; then
      src="$murl"
    fi
  fi

  # Ensure the bundle checkout: clone if absent, else best-effort fast-forward.
  if [ -d "$bundle/.git" ]; then
    echo "  BUNDLE: updating existing checkout at $bundle"
    git -C "$bundle" pull --ff-only >/dev/null 2>&1 || echo "  BUNDLE: pull skipped (offline / diverged) — using current checkout"
  else
    if [ -z "$src" ]; then
      echo "ERROR: cannot bootstrap the bundle — no clone source. Set SKILLS_DEPLOY_BUNDLE_SOURCE, or install once normally so the manifest records .source/upstream_url." >&2
      return 1
    fi
    echo "  BUNDLE: cloning $src into $bundle"
    mkdir -p "$(dirname "$bundle")"
    if ! git clone --quiet "$src" "$bundle" 2>/dev/null; then
      echo "ERROR: git clone failed ($src into $bundle)" >&2
      return 1
    fi
  fi

  # The bundle must be a workbench checkout (carry its own skills-deploy).
  if [ ! -x "$bundle/scripts/skills-deploy" ]; then
    echo "ERROR: $bundle is not a workbench checkout (no scripts/skills-deploy)" >&2
    return 1
  fi

  # Delegate: the bundle's own skills-deploy install resolves REPO_ROOT to the
  # bundle, so the flat /CJ_* dirs symlink INTO the bundle. Env target overrides
  # propagate to the child process.
  echo "  BUNDLE: installing the CJ_ family FROM the bundle checkout"
  if ! bash "$bundle/scripts/skills-deploy" install "$@"; then
    echo "ERROR: bundle-delegated install failed" >&2
    return 1
  fi

  # Stamp the manifest with the install==clone receipt.
  local bcommit m
  bcommit=$(git -C "$bundle" rev-parse --short HEAD 2>/dev/null || echo unknown)
  m=$(manifest_read 2>/dev/null || echo '{}')
  echo "$m" | jq --arg bp "$bundle" --arg bc "$bcommit" \
    '. + {install_mode: "bundle", bundle_path: $bp, bundle_commit: $bc}' | manifest_write

  echo ""
  echo "Bundle install complete — install == clone at $bundle (commit $bcommit)"
  echo "  Flat /CJ_* skills now resolve INTO the bundle checkout."
  echo "  Legacy dev-clone install is untouched; run 'skills-deploy install' (no --bundle) to revert."
}

do_install() {
  require_jq
  local skills=() overwrite=true from_upgrade="" bundle_mode=false
  local args=()
  local prev=""
  for arg in "$@"; do
    if [ "$prev" = "--from-upgrade" ]; then
      from_upgrade="$arg"
      prev=""
      continue
    fi
    case "$arg" in
      --overwrite) overwrite=true ;;
      --no-overwrite) overwrite=false ;;
      --bundle) bundle_mode=true ;;
      --from-upgrade) prev="--from-upgrade" ;;
      *) args+=("$arg") ;;
    esac
  done
  if [ "$prev" = "--from-upgrade" ]; then
    echo "ERROR: --from-upgrade requires a version value" >&2
    exit 2
  fi
  if [ -n "$from_upgrade" ]; then
    if ! printf '%s' "$from_upgrade" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
      echo "ERROR: --from-upgrade value '$from_upgrade' is not a valid 3-digit semver" >&2
      exit 2
    fi
  fi
  set -- "${args[@]+"${args[@]}"}"

  # F000049 / S2 (S000086): --bundle mode (install == clone). Short-circuits the
  # normal dev-clone install: ensure a managed git checkout of the workbench at
  # the bundle path, then delegate to THAT checkout's own skills-deploy so the
  # flat /CJ_* skill dirs symlink INTO the bundle (gstack's install==clone layout).
  # Additive + opt-in — the default `install` (dev-clone symlinks) is untouched.
  if [ "$bundle_mode" = true ]; then
    local _fwd=()
    [ "$overwrite" = false ] && _fwd+=(--no-overwrite)
    do_bundle_install "${_fwd[@]+"${_fwd[@]}"}" "$@"
    return $?
  fi

  if [ $# -gt 0 ]; then
    skills=("$@")
    # Resolve dependencies
    local resolved=()
    for s in "${skills[@]}"; do
      for dep in $(skill_deps "$s"); do
        # Add dep if not already in list
        local found=0
        for r in "${resolved[@]+"${resolved[@]}"}"; do [ "$r" = "$dep" ] && found=1; done
        [ "$found" -eq 0 ] && resolved+=("$dep")
      done
      resolved+=("$s")
    done
    skills=("${resolved[@]}")
  else
    while IFS= read -r s; do skills+=("$s"); done < <(discover_skills)
  fi

  local manifest installed=0 skipped=0 migrated=0
  manifest=$(manifest_read)

  # Resolve install mode ONCE per run (S000079). symlink-capable platforms
  # (macOS/Linux/WSL2) take the byte-identical legacy `ln -snf` path; Git Bash
  # (no usable symlinks) falls back to copy-mode (`cp` + recorded source_checksums).
  local install_kind
  if [ "$(_can_symlink)" = "yes" ]; then
    install_kind="symlink"
  else
    install_kind="copy"
    echo "  INFO: symlinks unavailable in $SKILLS_TARGET — installing skills in copy-mode"
  fi

  for name in "${skills[@]}"; do
    # Source directory is catalog-driven (F000006): dirname(files[0]). Empty
    # for templates-only entries (handled below).
    local src
    src=$(skill_source_dir "$name")
    # Templates-only catalog entries have no skill directory (empty files array)
    local files_count
    files_count=$(jq -r --arg n "$name" '.[] | select(.name == $n) | .files | length' "$CATALOG" 2>/dev/null || echo "0")
    # -n guard: a catalog-absent name yields empty (jq match miss, exit 0) — avoid
    # the "integer expression expected" crash (same class as do_remove's fc_rm).
    if [ -n "$files_count" ] && [ "$files_count" -eq 0 ]; then
      echo "  OK: $name is templates-only (no skill directory)"
      manifest=$(echo "$manifest" | jq --arg n "$name" --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        '.skills[$n] = {templates_only: true, installed_at: $t}')
      installed=$((installed + 1))
      continue
    fi
    if [ ! -d "$src" ]; then
      echo "  SKIP: $name not found in repo" >&2
      skipped=$((skipped + 1))
      continue
    fi

    local owner
    owner=$(skill_owner "$name")

    case "$owner" in
      gstack)
        echo "  SKIP: $name is owned by gstack"
        skipped=$((skipped + 1))
        continue
        ;;
      other)
        echo "  SKIP: $name is owned by another tool"
        skipped=$((skipped + 1))
        continue
        ;;
      manual)
        # Migration: check if files match repo
        local dominated=true
        for f in "$SKILLS_TARGET/$name"/*.md; do
          [ -f "$f" ] || continue
          local fname
          fname=$(basename "$f")
          if [ -f "$src/$fname" ]; then
            if ! diff -q "$f" "$src/$fname" >/dev/null 2>&1; then
              echo "  WARN: $name/$fname has local modifications, skipping migration"
              dominated=false
              break
            fi
          fi
        done
        if [ "$dominated" = false ]; then
          skipped=$((skipped + 1))
          continue
        fi
        echo "  MIGRATE: $name (flat copy -> symlinks)"
        migrated=$((migrated + 1))
        # Remove old files, recreate as symlinks below
        rm -f "$SKILLS_TARGET/$name"/*.md 2>/dev/null || true
        ;;
      ours)
        # Update existing symlinks
        ;;
      none)
        mkdir -p "$SKILLS_TARGET/$name"
        ;;
    esac

    # Install all .md and .json files from source. symlink-mode: byte-identical
    # legacy `ln -snf`. copy-mode (S000079): `cp` the file + accumulate its SHA256
    # into a per-skill source_checksums object (keyed by filename) so copy-mode
    # doctor/relink have a source of truth to verify against.
    local checksums_json="{}"
    for f in "$src"/*.md "$src"/*.json; do
      [ -f "$f" ] || continue
      local fname
      fname=$(basename "$f")
      # Skip dev-only files
      case "$fname" in CHANGELOG.md|DESIGN.md) continue ;; esac
      if [ "$install_kind" = "symlink" ]; then
        ln -snf "$f" "$SKILLS_TARGET/$name/$fname"
      else
        # Replace any pre-existing symlink/file with a regular-file copy.
        rm -f "$SKILLS_TARGET/$name/$fname" 2>/dev/null || true
        cp "$f" "$SKILLS_TARGET/$name/$fname"
        local fsum
        fsum=$(file_checksum "$f"); [ -n "$fsum" ] || fsum="unknown"
        checksums_json=$(echo "$checksums_json" | jq --arg k "$fname" --arg v "$fsum" '.[$k] = $v')
      fi
    done

    # Install subdirectories from source (examples/, reference/, philosophy/, fixtures/).
    # symlink-mode: legacy `ln -snf`. copy-mode (S000079): rm -rf + cp -R (recursive
    # copy). Subdir contents are presence-checked by doctor, not deep-hashed.
    for d in "$src"/*/; do
      [ -d "$d" ] || continue
      local dname
      dname=$(basename "$d")
      local dtarget="$SKILLS_TARGET/$name/$dname"
      # Migration guard: if target is a real dir (not symlink), diff before replacing
      if [ -d "$dtarget" ] && [ ! -L "$dtarget" ]; then
        local ddom=true
        for df in "$dtarget"/*; do
          [ -f "$df" ] || continue
          local dfname
          dfname=$(basename "$df")
          if [ -f "$d/$dfname" ]; then
            if ! diff -q "$df" "$d/$dfname" >/dev/null 2>&1; then
              echo "  WARN: $name/$dname/$dfname has local modifications, skipping subdir migration"
              ddom=false
              break
            fi
          fi
        done
        if [ "$ddom" = true ]; then
          rm -rf "$dtarget"
        else
          continue
        fi
      fi
      if [ "$install_kind" = "symlink" ]; then
        ln -snf "$d" "$dtarget"
      else
        rm -rf "$dtarget" 2>/dev/null || true
        cp -R "$d" "$dtarget"
      fi
    done

    # Manifest path comes from catalog files[0] so it reflects the real source
    # location, not a guess. symlink-mode records {path, installed_at, install_kind};
    # copy-mode additionally records source_checksums for drift detection (S000079).
    local manifest_path
    manifest_path=$(skill_md_path "$name")
    if [ "$install_kind" = "symlink" ]; then
      manifest=$(echo "$manifest" | jq --arg n "$name" --arg p "$manifest_path" --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        '.skills[$n] = {path: $p, installed_at: $t, install_kind: "symlink"}')
    else
      manifest=$(echo "$manifest" | jq --arg n "$name" --arg p "$manifest_path" --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" --argjson sc "$checksums_json" \
        '.skills[$n] = {path: $p, installed_at: $t, install_kind: "copy", source_checksums: $sc}')
    fi
    installed=$((installed + 1))
  done

  # Deploy templates for installed skills
  local tpl_installed=0 tpl_skipped=0
  mkdir -p "$TEMPLATES_TARGET"

  for name in "${skills[@]}"; do
    # Source dir is catalog-driven (F000006); empty for templates-only entries.
    local src
    src=$(skill_source_dir "$name")
    # Templates-only entries have no skill directory but still deploy templates
    local fc
    fc=$(jq -r --arg n "$name" '.[] | select(.name == $n) | .files | length' "$CATALOG" 2>/dev/null || echo "0")
    # -n guard: a catalog-absent name yields empty (jq match miss, exit 0) — avoid
    # the "integer expression expected" crash (same class as do_remove's fc_rm).
    if [ -n "$fc" ] && [ "$fc" -ne 0 ]; then
      [ -d "$src" ] || continue
      # Skip skills we didn't actually install (gstack/other owned)
      local owner
      owner=$(skill_owner "$name")
      case "$owner" in gstack|other) continue ;; esac
    fi

    # Templates source base (F000006): default "templates" preserves existing
    # behavior; override via catalog templates_source field for skills whose
    # template source lives elsewhere.
    local tpl_base
    tpl_base=$(skill_templates_source "$name")

    for tpl in $(skill_templates "$name"); do
      validate_template_name "$tpl" || { tpl_skipped=$((tpl_skipped + 1)); continue; }

      # When templates_source is the default, entry is path under templates/.
      # When overridden, entry's basename is joined with the override base —
      # the {skill}/ prefix in the entry is the DST organizing subfolder, not
      # part of the SRC path under the override.
      local tpl_src
      if [ "$tpl_base" = "templates" ]; then
        tpl_src="$TEMPLATES_SRC/$tpl"
      else
        tpl_src="$REPO_ROOT/$tpl_base/$(basename "$tpl")"
      fi
      local tpl_dst="$TEMPLATES_TARGET/$tpl"
      mkdir -p "$(dirname "$tpl_dst")"

      # Check for shadowing by higher-priority path
      if [ -f "$HOME/.claude/spec/templates/$tpl" ]; then
        echo "  WARN: $tpl — shadowed by ~/.claude/spec/templates/$tpl (takes priority; remove it to use deployed version)"
      fi

      if [ ! -f "$tpl_src" ]; then
        echo "  WARN: $tpl — source not found at $tpl_src, skipping"
        tpl_skipped=$((tpl_skipped + 1))
        continue
      fi

      local src_sum
      src_sum=$(file_checksum "$tpl_src")
      if [ "$src_sum" = "" ]; then src_sum="unknown"; fi

      if [ -f "$tpl_dst" ]; then
        local dst_sum
        dst_sum=$(file_checksum "$tpl_dst")
        if [ "$src_sum" = "$dst_sum" ]; then
          # Same content — just update ownership
          manifest=$(echo "$manifest" | jq --arg t "$tpl" --arg s "$name" --arg sum "$src_sum" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            '.templates[$t] = (.templates[$t] // {owners: [], source_checksum: $sum, installed_at: $ts}) | .templates[$t].owners = ([.templates[$t].owners // [] | .[] | select(. != $s)] + [$s]) | .templates[$t].source_checksum = $sum')
        elif [ "$overwrite" = true ]; then
          cp "$tpl_src" "$tpl_dst" || { echo "  WARN: failed to copy $tpl"; tpl_skipped=$((tpl_skipped + 1)); continue; }
          echo "  UPDATE: $tpl (checksum differs)"
          manifest=$(echo "$manifest" | jq --arg t "$tpl" --arg s "$name" --arg sum "$src_sum" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            '.templates[$t] = (.templates[$t] // {owners: [], source_checksum: $sum, installed_at: $ts}) | .templates[$t].owners = ([.templates[$t].owners // [] | .[] | select(. != $s)] + [$s]) | .templates[$t].source_checksum = $sum')
          tpl_installed=$((tpl_installed + 1))
        else
          echo "  PRESERVE: $tpl — exists with different content (--no-overwrite, keeping deployed copy)"
          # Still update ownership even if we skip the copy
          manifest=$(echo "$manifest" | jq --arg t "$tpl" --arg s "$name" --arg sum "$dst_sum" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            '.templates[$t] = (.templates[$t] // {owners: [], source_checksum: $sum, installed_at: $ts}) | .templates[$t].owners = ([.templates[$t].owners // [] | .[] | select(. != $s)] + [$s])')
          tpl_skipped=$((tpl_skipped + 1))
        fi
      else
        cp "$tpl_src" "$tpl_dst" || { echo "  WARN: failed to copy $tpl"; tpl_skipped=$((tpl_skipped + 1)); continue; }
        manifest=$(echo "$manifest" | jq --arg t "$tpl" --arg s "$name" --arg sum "$src_sum" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
          '.templates[$t] = (.templates[$t] // {owners: [], source_checksum: $sum, installed_at: $ts}) | .templates[$t].owners = ([.templates[$t].owners // [] | .[] | select(. != $s)] + [$s]) | .templates[$t].source_checksum = $sum')
        tpl_installed=$((tpl_installed + 1))
      fi
    done
  done

  # Deploy rules files (global Claude Code rules from rules/ directory)
  local rules_installed=0
  if [ -d "$RULES_SRC" ]; then
    mkdir -p "$RULES_TARGET"
    for rule_file in "$RULES_SRC"/*.md; do
      [ -f "$rule_file" ] || continue
      local rule_name
      rule_name=$(basename "$rule_file")
      # Skip documentation files not intended as global Claude Code instructions.
      case "$rule_name" in README.md|NOTES.md|DEVELOPMENT.md|CHANGELOG.md) continue ;; esac
      local rule_dst="$RULES_TARGET/$rule_name"
      if [ -f "$rule_dst" ]; then
        local rule_src_sum rule_dst_sum
        rule_src_sum=$(file_checksum "$rule_file")
        rule_dst_sum=$(file_checksum "$rule_dst")
        if [ "$rule_src_sum" = "$rule_dst_sum" ]; then
          continue
        elif [ "$overwrite" = true ]; then
          cp "$rule_file" "$rule_dst" || { echo "  WARN: failed to copy $rule_name (skipping)"; continue; }
          echo "  RULE: updated $rule_name"
          rules_installed=$((rules_installed + 1))
        else
          echo "  WARN: $rule_name — rule exists with different content (--no-overwrite, keeping deployed copy; routing drift possible)"
        fi
      else
        cp "$rule_file" "$rule_dst" || { echo "  WARN: failed to copy $rule_name (skipping)"; continue; }
        echo "  RULE: installed $rule_name"
        rules_installed=$((rules_installed + 1))
      fi
    done
  fi

  # Deploy shared scripts to _cj-shared/scripts/ (F000049 / S000085).
  # The shared scripts/*.sh helpers (+ skills-update-check) travel with the
  # install so the orchestrator-family skills (CJ_goal_feature / CJ_goal_defect /
  # CJ_goal_todo_fix / CJ_document-release) resolve them from this deployed home
  # (bundle-first, .source legacy fallback) instead of a separate source clone.
  # Copy-mode + SHA256 drift tracking, like templates. Deposited as a SET so the
  # scripts' dirname-relative sibling resolution (BASH_SOURCE) keeps every
  # transitive helper co-located in one dir.
  local shared_installed=0 shared_skipped=0
  if [ -d "$SHARED_SCRIPTS_SRC" ]; then
    mkdir -p "$SHARED_SCRIPTS_TARGET"
    for sh_src in "$SHARED_SCRIPTS_SRC"/*.sh "$SHARED_SCRIPTS_SRC/skills-update-check"; do
      [ -f "$sh_src" ] || continue
      local sh_base sh_dst sh_src_sum
      sh_base=$(basename "$sh_src")
      sh_dst="$SHARED_SCRIPTS_TARGET/$sh_base"
      sh_src_sum=$(file_checksum "$sh_src")
      [ -n "$sh_src_sum" ] || sh_src_sum="unknown"
      if [ -f "$sh_dst" ]; then
        local sh_dst_sum
        sh_dst_sum=$(file_checksum "$sh_dst")
        if [ "$sh_src_sum" = "$sh_dst_sum" ]; then
          :  # same content — fall through to refresh the manifest record
        elif [ "$overwrite" = true ]; then
          cp "$sh_src" "$sh_dst" || { echo "  WARN: failed to copy shared script $sh_base (skipping)"; shared_skipped=$((shared_skipped + 1)); continue; }
          chmod +x "$sh_dst" 2>/dev/null || true
          echo "  SHARED: updated $sh_base (checksum differs)"
          shared_installed=$((shared_installed + 1))
        else
          echo "  WARN: $sh_base — shared script exists with different content (--no-overwrite, keeping deployed copy)"
          sh_src_sum="$sh_dst_sum"
          shared_skipped=$((shared_skipped + 1))
        fi
      else
        cp "$sh_src" "$sh_dst" || { echo "  WARN: failed to copy shared script $sh_base (skipping)"; shared_skipped=$((shared_skipped + 1)); continue; }
        chmod +x "$sh_dst" 2>/dev/null || true
        shared_installed=$((shared_installed + 1))
      fi
      manifest=$(echo "$manifest" | jq --arg k "$sh_base" --arg sum "$sh_src_sum" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        '.shared_scripts[$k] = {source_checksum: $sum, installed_at: $ts}')
    done
  fi

  # Resolve the manifest `source` to the MAIN repo toplevel (T000025).
  # `$REPO_ROOT` (line 7) is `dirname(script)/..`, which under `.claude/worktrees/<name>/`
  # points at the ephemeral worktree. Once the worktree is removed, `skills-deploy doctor`
  # reports `FAIL: source path '<dead-worktree>' no longer exists`, and update-check's
  # `git pull --ff-only` fallback silently breaks. `git rev-parse --path-format=absolute
  # --git-common-dir` resolves the main repo's `.git` dir regardless of which worktree
  # the script ran from; its parent is the main toplevel. Fallback to `$REPO_ROOT` if
  # the git call fails (e.g. when the repo is unusual or in a non-worktree context).
  local main_toplevel
  main_toplevel=$(dirname "$(git -C "$REPO_ROOT" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" 2>/dev/null) || true
  if [ -z "$main_toplevel" ] || [ ! -d "$main_toplevel" ]; then
    main_toplevel="$REPO_ROOT"
  fi

  # Read collection version from the SAME repo the manifest `source` points at.
  # Must be `$main_toplevel`, not `$REPO_ROOT`: `doctor` later reads
  # `current_cv` from `$source/VERSION` (= `$main_toplevel/VERSION`). Sourcing
  # `col_ver` from `$REPO_ROOT/VERSION` (the ephemeral worktree, routinely ahead
  # of the stale main checkout during worktree-based dev) split the two endpoints
  # of doctor's drift check across two different VERSION files, emitting a
  # spurious "installed != current" WARN on every healthy worktree install
  # (T000025 moved `source` but left this read on `$REPO_ROOT`). The exact
  # deployed HEAD is still captured separately in the manifest `commit` field.
  local col_ver="unknown"
  if [ -f "$main_toplevel/VERSION" ]; then
    col_ver=$(tr -d '[:space:]' < "$main_toplevel/VERSION")
  fi

  # Capture origin URL at install time (T000031). Stored in manifest so
  # skills-update-check can verify it hasn't been redirected before recommending
  # `git pull --ff-only origin main` against `$source`. Empty when the source
  # repo has no `origin` remote (rare; skill installs from non-git source dir).
  local upstream_url
  upstream_url=$(git -C "$main_toplevel" remote get-url origin 2>/dev/null || true)

  # Write manifest
  echo "$manifest" | jq --arg s "$main_toplevel" --arg r "jcl2018/claude-skills-templates" \
    --arg c "$(git -C "$REPO_ROOT" rev-parse --short HEAD 2>/dev/null || echo unknown)" \
    --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --arg cv "$col_ver" \
    --arg u "$upstream_url" \
    '. + {source: $s, repo: $r, commit: $c, installed_at: $t, collection_version: $cv, upstream_url: $u}' | manifest_write

  # Write JUST_UPGRADED marker if invoked from the update-check upgrade flow.
  # Format: single line "<from_version> <to_version>" — consumed once by
  # skills-update-check (read, unlink, emit) on the next skill invocation.
  if [ -n "$from_upgrade" ]; then
    local marker_path="${SKILLS_TEMPLATES_MARKER:-$HOME/.claude/.skills-templates-just-upgraded}"
    printf '%s %s\n' "$from_upgrade" "$col_ver" > "$marker_path" 2>/dev/null || true
  fi

  echo ""
  echo "Skills — Installed: $installed  Migrated: $migrated  Skipped: $skipped"
  echo "Templates — Installed: $tpl_installed  Skipped: $tpl_skipped"
  if [ "$rules_installed" -gt 0 ]; then
    echo "Rules — Installed: $rules_installed"
  fi
  if [ "$shared_installed" -gt 0 ] || [ "$shared_skipped" -gt 0 ]; then
    echo "Shared scripts — Installed: $shared_installed  Skipped: $shared_skipped"
  fi
}

# --- remove ---

do_remove() {
  require_jq
  local force=false remove_all=false
  local skills=()

  for arg in "$@"; do
    case "$arg" in
      --all) remove_all=true; while IFS= read -r s; do skills+=("$s"); done < <(manifest_read | jq -r '.skills // {} | keys[]'); continue ;;
      --force) force=true; continue ;;
      *) skills+=("$arg") ;;
    esac
  done

  if [ ${#skills[@]} -eq 0 ]; then
    echo "ERROR: specify skill names or --all" >&2
    echo "Usage: skills-deploy remove <skill...> [--force]" >&2
    echo "       skills-deploy remove --all [--force]" >&2
    exit 1
  fi

  local manifest removed=0 template_errors=0
  manifest=$(manifest_read)

  for name in "${skills[@]}"; do
    # Check reverse dependencies
    if [ "$force" = false ]; then
      for rdep in $(reverse_deps "$name"); do
        if echo "$manifest" | jq -e --arg n "$rdep" '.skills[$n]' >/dev/null 2>&1; then
          echo "  WARN: $name is required by $rdep (installed). Use --force to remove anyway."
          continue 2
        fi
      done
    fi

    # Check if this is a templates-only entry
    local tpl_only=false
    local fc_rm
    fc_rm=$(jq -r --arg n "$name" '.[] | select(.name == $n) | .files | length' "$CATALOG" 2>/dev/null || echo "0")
    # A catalog-absent skill (deprecated/renamed but still deployed) makes the jq
    # `select` match nothing → empty output + jq exit 0, which defeats the
    # `|| echo "0"` fallback (it only catches jq *failure*). The -n guard stops
    # `[ "" -eq 0 ]` from erroring "integer expression expected". Empty (absent)
    # MUST stay tpl_only=false so the dir-removal block below still runs — do NOT
    # default empty→0 (that sets tpl_only=true, skips removal, orphans the dir).
    [ -n "$fc_rm" ] && [ "$fc_rm" -eq 0 ] && tpl_only=true

    # Read the recorded install_kind for this skill (S000079). Absent field →
    # "symlink" (back-compat: installs predating the field were all symlinks).
    local rm_kind
    rm_kind=$(echo "$manifest" | jq -r --arg n "$name" '.skills[$n].install_kind // "symlink"')

    if [ "$tpl_only" = false ]; then
      if [ "$rm_kind" = "copy" ]; then
        # Copy-mode: the installed files are regular-file copies we own. Remove the
        # recorded regular files + any copied subdirs. skill_owner() returns "manual"
        # for regular files, so the symlink-mode ownership gate is skipped here; the
        # manifest install_kind=copy record is the ownership signal.
        for f in "$SKILLS_TARGET/$name"/*.md "$SKILLS_TARGET/$name"/*.json; do
          [ -f "$f" ] && [ ! -L "$f" ] && rm -f "$f"
        done
        for d in "$SKILLS_TARGET/$name"/*/; do
          local dpath
          dpath="$(dirname "$d")/$(basename "$d")"
          [ -d "$dpath" ] && [ ! -L "$dpath" ] && rm -rf "$dpath"
        done
        rmdir "$SKILLS_TARGET/$name" 2>/dev/null || true
      else
        # Verify ownership before removing
        local owner
        owner=$(skill_owner "$name")
        if [ "$owner" != "ours" ]; then
          echo "  SKIP: $name is not owned by this repo (owner: $owner)"
          continue
        fi

        # Remove symlinks only (not regular files)
        for f in "$SKILLS_TARGET/$name"/*.md "$SKILLS_TARGET/$name"/*.json; do
          [ -L "$f" ] && rm -f "$f"
        done
        # Remove subdirectory symlinks
        for d in "$SKILLS_TARGET/$name"/*/; do
          local dpath
          dpath="$(dirname "$d")/$(basename "$d")"
          [ -L "$dpath" ] && rm -f "$dpath"
        done
        rmdir "$SKILLS_TARGET/$name" 2>/dev/null || true
      fi
    fi

    # Clean up templates owned by this skill
    for tpl in $(skill_templates "$name"); do
      validate_template_name "$tpl" || continue
      # Remove this skill from owners
      manifest=$(echo "$manifest" | jq --arg t "$tpl" --arg s "$name" \
        'if .templates[$t] then .templates[$t].owners = [.templates[$t].owners // [] | .[] | select(. != $s)] else . end')
      # If no owners left, delete template file and manifest entry
      local owner_count
      owner_count=$(echo "$manifest" | jq --arg t "$tpl" '.templates[$t].owners // [] | length')
      if [ "$owner_count" -eq 0 ]; then
        if [ -f "$TEMPLATES_TARGET/$tpl" ]; then
          if rm -f "$TEMPLATES_TARGET/$tpl"; then
            echo "  TEMPLATE: removed $tpl"
          else
            echo "  WARN: failed to remove $tpl"
            template_errors=$((template_errors + 1))
          fi
        fi
        manifest=$(echo "$manifest" | jq --arg t "$tpl" 'del(.templates[$t])')
      fi
    done

    manifest=$(echo "$manifest" | jq --arg n "$name" 'del(.skills[$n])')
    removed=$((removed + 1))
  done

  # Clean up deployed rules only when removing all skills (rules are global, not per-skill).
  if [ "$remove_all" = true ] && [ -d "$RULES_SRC" ]; then
    for rule_file in "$RULES_SRC"/*.md; do
      [ -f "$rule_file" ] || continue
      local rule_name
      rule_name=$(basename "$rule_file")
      case "$rule_name" in README.md|NOTES.md|DEVELOPMENT.md|CHANGELOG.md) continue ;; esac
      if [ -f "$RULES_TARGET/$rule_name" ]; then
        if rm -f "$RULES_TARGET/$rule_name"; then
          echo "  RULE: removed $rule_name"
        fi
      fi
    done
  fi

  # Prune orphaned template owners (owners referencing skills no longer installed)
  local installed_skills
  installed_skills=$(echo "$manifest" | jq -r '[.skills // {} | keys[]] | join(",")')
  for tpl in $(echo "$manifest" | jq -r '.templates // {} | keys[]'); do
    manifest=$(echo "$manifest" | jq --arg t "$tpl" --arg installed "$installed_skills" \
      '.templates[$t].owners = [.templates[$t].owners // [] | .[] | select(. as $o | ($installed | split(",")) | index($o))]')
    local owner_count
    owner_count=$(echo "$manifest" | jq --arg t "$tpl" '.templates[$t].owners // [] | length')
    if [ "$owner_count" -eq 0 ]; then
      [ -f "$TEMPLATES_TARGET/$tpl" ] && rm -f "$TEMPLATES_TARGET/$tpl"
      manifest=$(echo "$manifest" | jq --arg t "$tpl" 'del(.templates[$t])')
    fi
  done

  # Write manifest or remove if empty
  local remaining tpl_remaining
  remaining=$(echo "$manifest" | jq '.skills // {} | length')
  tpl_remaining=$(echo "$manifest" | jq '.templates // {} | length')
  if [ "$remaining" -eq 0 ] && [ "$tpl_remaining" -eq 0 ] && [ "$template_errors" -eq 0 ]; then
    rm -f "$MANIFEST"
    echo "Removed: $removed (manifest cleaned up)"
  else
    echo "$manifest" | manifest_write
    echo "Removed: $removed"
  fi
}

# --- relink ---

do_relink() {
  require_jq
  local manifest fixed=0 ok=0
  manifest=$(manifest_read)

  if [ "$(echo "$manifest" | jq '.skills // {} | length')" -eq 0 ]; then
    echo "No skills in manifest. Run 'skills-deploy install' first."
    return
  fi

  local source
  source=$(echo "$manifest" | jq -r '.source // ""')

  for name in $(echo "$manifest" | jq -r '.skills // {} | keys[]'); do
    # Source dir is catalog-driven (F000006): read manifest .skills[$n].path,
    # then dirname it. Falls back to the legacy skills/{name}/ shape when the
    # manifest has no path field (older installs from before F000006).
    local manifest_path
    manifest_path=$(echo "$manifest" | jq -r --arg n "$name" '.skills[$n].path // ""')
    local src
    if [ -n "$manifest_path" ]; then
      src="$source/$(dirname "$manifest_path")"
    else
      src="$source/skills/$name"
    fi
    if [ ! -d "$src" ]; then
      echo "  WARN: $name source missing at $src"
      continue
    fi

    # Branch on recorded install_kind (S000079); absent field → "symlink"
    # (back-compat for installs predating the field).
    local rl_kind
    rl_kind=$(echo "$manifest" | jq -r --arg n "$name" '.skills[$n].install_kind // "symlink"')

    mkdir -p "$SKILLS_TARGET/$name"
    for f in "$src"/*.md "$src"/*.json; do
      [ -f "$f" ] || continue
      local fname
      fname=$(basename "$f")
      case "$fname" in CHANGELOG.md|DESIGN.md) continue ;; esac
      local target="$SKILLS_TARGET/$name/$fname"
      if [ "$rl_kind" = "copy" ]; then
        # Re-copy when the installed file is missing or its SHA drifted from the
        # recorded source_checksums entry (mirrors template relink-on-drift below).
        local expected_sum actual_sum
        expected_sum=$(echo "$manifest" | jq -r --arg n "$name" --arg k "$fname" '.skills[$n].source_checksums[$k] // ""')
        if [ -f "$target" ] && [ ! -L "$target" ]; then
          actual_sum=$(file_checksum "$target")
        else
          actual_sum=""
        fi
        if [ -n "$actual_sum" ] && [ "$actual_sum" = "$expected_sum" ]; then
          ok=$((ok + 1))
        else
          rm -f "$target" 2>/dev/null || true
          cp "$f" "$target"
          fixed=$((fixed + 1))
        fi
      else
        if [ -L "$target" ] && [ "$(readlink "$target")" = "$f" ]; then
          ok=$((ok + 1))
        else
          ln -snf "$f" "$target"
          fixed=$((fixed + 1))
        fi
      fi
    done

    # Repair subdirectories. copy-mode: presence-check + re-copy if missing.
    # symlink-mode: legacy symlink repair.
    for d in "$src"/*/; do
      [ -d "$d" ] || continue
      local dname
      dname=$(basename "$d")
      local dtarget="$SKILLS_TARGET/$name/$dname"
      if [ "$rl_kind" = "copy" ]; then
        if [ -d "$dtarget" ] && [ ! -L "$dtarget" ]; then
          ok=$((ok + 1))
        else
          rm -rf "$dtarget" 2>/dev/null || true
          cp -R "$d" "$dtarget"
          fixed=$((fixed + 1))
        fi
      else
        if [ -L "$dtarget" ] && [ -e "$dtarget" ]; then
          ok=$((ok + 1))
        else
          ln -snf "$d" "$dtarget"
          fixed=$((fixed + 1))
        fi
      fi
    done
  done

  # Repair templates
  local tpl_fixed=0 tpl_ok=0
  for tpl in $(echo "$manifest" | jq -r '.templates // {} | keys[]'); do
    local tpl_file="$TEMPLATES_TARGET/$tpl"
    local tpl_src="$TEMPLATES_SRC/$tpl"

    if [ ! -f "$tpl_file" ]; then
      # Missing — re-copy if source exists
      if [ -f "$tpl_src" ]; then
        mkdir -p "$(dirname "$tpl_file")"
        cp "$tpl_src" "$tpl_file" && tpl_fixed=$((tpl_fixed + 1)) || echo "  WARN: failed to restore $tpl"
        # Update checksum in manifest
        local new_sum
        new_sum=$(file_checksum "$tpl_src")
        manifest=$(echo "$manifest" | jq --arg t "$tpl" --arg sum "$new_sum" '.templates[$t].source_checksum = $sum')
      else
        echo "  WARN: $tpl — source not found at $tpl_src, cannot restore"
      fi
    else
      local expected actual
      expected=$(echo "$manifest" | jq -r --arg t "$tpl" '.templates[$t].source_checksum // ""')
      actual=$(file_checksum "$tpl_file")
      if [ -n "$expected" ] && [ "$expected" != "$actual" ] && [ "$expected" != "unknown" ]; then
        echo "  WARN: $tpl has local changes. Run 'skills-deploy install' to reset (or pass --no-overwrite to keep them)."
      else
        tpl_ok=$((tpl_ok + 1))
      fi
    fi
  done

  # Write updated manifest if templates were repaired
  if [ "$tpl_fixed" -gt 0 ]; then
    echo "$manifest" | manifest_write
  fi

  echo "Skills — Relinked: $fixed fixed, $ok already correct"
  echo "Templates — Restored: $tpl_fixed, OK: $tpl_ok"
}

# --- doctor ---

do_doctor() {
  require_jq
  local errors=0 warnings=0

  if [ ! -f "$MANIFEST" ]; then
    echo "No manifest found at $MANIFEST"
    echo "Run 'skills-deploy install' to create one."
    return
  fi

  local manifest
  manifest=$(cat "$MANIFEST")
  local source
  source=$(echo "$manifest" | jq -r '.source // ""')

  echo "=== skills-deploy doctor ==="
  echo "Source: $source"
  echo "Manifest: $MANIFEST"

  # Collection version check
  local installed_cv
  installed_cv=$(echo "$manifest" | jq -r '.collection_version // "unknown"')
  echo "Collection version (installed): $installed_cv"
  if [ -n "$source" ] && [ -f "$source/VERSION" ]; then
    local current_cv
    current_cv=$(tr -d '[:space:]' < "$source/VERSION")
    echo "Collection version (current):   $current_cv"
    if [ "$installed_cv" = "$current_cv" ]; then
      echo "  OK: up to date"
    elif [ "$installed_cv" = "unknown" ]; then
      echo "  WARN: installed before collection versioning. Run 'skills-deploy install' to update."
      warnings=$((warnings + 1))
    else
      echo "  WARN: installed version ($installed_cv) differs from current ($current_cv)."
      echo "  Fix: run 'skills-deploy install' to update, or 'cd $source && git pull' first."
      warnings=$((warnings + 1))
    fi
  elif [ -n "$source" ] && [ ! -d "$source" ]; then
    echo "  FAIL: source path '$source' no longer exists. Re-run 'skills-deploy install' from a valid clone."
    errors=$((errors + 1))
  fi

  # Update-check cache surface (skills-update-check state).
  local cache_file="${SKILLS_TEMPLATES_CACHE:-$HOME/.claude/.skills-templates-update.json}"
  if [ -f "$cache_file" ]; then
    local cache_local cache_remote cache_checked cache_snooze cache_skip
    cache_local=$(jq -r '.local_version // empty' "$cache_file" 2>/dev/null || echo "")
    cache_remote=$(jq -r '.remote_version // empty' "$cache_file" 2>/dev/null || echo "")
    cache_checked=$(jq -r '.checked_at // empty' "$cache_file" 2>/dev/null || echo "")
    cache_snooze=$(jq -r '.snooze_until // empty' "$cache_file" 2>/dev/null || echo "")
    cache_skip=$(jq -r '.skip_version // empty' "$cache_file" 2>/dev/null || echo "")
    echo "Update check:"
    if [ -n "$cache_checked" ]; then
      # Portable date formatting: try BSD then GNU.
      local checked_str
      checked_str=$(date -r "$cache_checked" 2>/dev/null || date -d "@$cache_checked" 2>/dev/null || echo "$cache_checked")
      echo "  Last check: $checked_str"
    else
      echo "  Last check: (never)"
    fi
    [ -n "$cache_local" ] && echo "  Cached local:  $cache_local"
    [ -n "$cache_remote" ] && echo "  Cached remote: $cache_remote"
    if [ -n "$cache_snooze" ]; then
      local now_ts
      now_ts=$(date +%s)
      if [ "$now_ts" -lt "$cache_snooze" ] 2>/dev/null; then
        local snooze_str
        snooze_str=$(date -r "$cache_snooze" 2>/dev/null || date -d "@$cache_snooze" 2>/dev/null || echo "$cache_snooze")
        echo "  Snoozed until: $snooze_str"
      fi
    fi
    [ -n "$cache_skip" ] && echo "  Skipping version: $cache_skip"
  else
    echo "Update check: (never run — runs on next skill invocation)"
  fi
  echo ""

  # Check each installed skill
  for name in $(echo "$manifest" | jq -r '.skills // {} | keys[]'); do
    # Source dir is catalog-driven (F000006): read manifest .skills[$n].path,
    # then dirname it. Falls back to skills/{name}/ for older installs.
    local manifest_path
    manifest_path=$(echo "$manifest" | jq -r --arg n "$name" '.skills[$n].path // ""')
    local src
    if [ -n "$manifest_path" ]; then
      src="$source/$(dirname "$manifest_path")"
    else
      src="$source/skills/$name"
    fi
    local target_dir="$SKILLS_TARGET/$name"
    local skill_md="$target_dir/SKILL.md"
    local _label
    _label="OK: $name"

    # Templates-only entries have no target directory
    if echo "$manifest" | jq -e --arg n "$name" '.skills[$n].templates_only' >/dev/null 2>&1; then
      echo "  OK: $name (templates-only)"
      continue
    fi

    # Branch on recorded install_kind (S000079); absent field → "symlink"
    # (back-compat for installs predating the field).
    local dr_kind
    dr_kind=$(echo "$manifest" | jq -r --arg n "$name" '.skills[$n].install_kind // "symlink"')

    if [ "$dr_kind" = "copy" ]; then
      # Copy-mode: verify each recorded source_checksums entry by re-hashing the
      # installed regular file; mismatch or missing → FAIL (mirrors the template
      # checksum FAIL below). Subdir contents are presence-checked, not deep-hashed.
      if [ ! -d "$target_dir" ]; then
        echo "  FAIL: $name — target directory missing"
        errors=$((errors + 1))
      else
        local copy_ok=true
        while IFS=$'\t' read -r cf csum; do
          [ -n "$cf" ] || continue
          local cfile="$target_dir/$cf"
          if [ ! -f "$cfile" ]; then
            echo "  FAIL: $name/$cf — file missing (copy-mode)"
            errors=$((errors + 1))
            copy_ok=false
          else
            local cactual
            cactual=$(file_checksum "$cfile")
            if [ "$csum" != "unknown" ] && [ -n "$csum" ] && [ "$cactual" != "$csum" ]; then
              echo "  FAIL: $name/$cf — content differs from source (copy-mode drift)"
              errors=$((errors + 1))
              copy_ok=false
            fi
          fi
        done < <(echo "$manifest" | jq -r --arg n "$name" '.skills[$n].source_checksums // {} | to_entries[] | .key + "\t" + .value')
        # Subdir presence-check (not deep-hashed) when source is available.
        if [ -d "$src" ]; then
          for sd in "$src"/*/; do
            [ -d "$sd" ] || continue
            local sdname
            sdname=$(basename "$sd")
            if [ ! -d "$target_dir/$sdname" ]; then
              echo "  FAIL: $name/$sdname — subdirectory missing (copy-mode)"
              errors=$((errors + 1))
              copy_ok=false
            fi
          done
        fi
        if [ "$copy_ok" = true ]; then
          echo "  $_label"
        fi
      fi
      continue
    fi

    if [ ! -d "$target_dir" ]; then
      echo "  FAIL: $name — target directory missing"
      errors=$((errors + 1))
    elif [ ! -L "$skill_md" ]; then
      echo "  WARN: $name — SKILL.md is not a symlink"
      warnings=$((warnings + 1))
    elif [ ! -e "$skill_md" ]; then
      echo "  FAIL: $name — broken symlink"
      errors=$((errors + 1))
    elif [ ! -d "$src" ]; then
      echo "  WARN: $name — source directory missing in repo"
      warnings=$((warnings + 1))
    else
      # Check subdirectory symlinks
      local subdir_ok=true
      for sd in "$src"/*/; do
        [ -d "$sd" ] || continue
        local sdname
        sdname=$(basename "$sd")
        local sdtarget="$target_dir/$sdname"
        if [ ! -e "$sdtarget" ]; then
          echo "  FAIL: $name/$sdname — subdirectory missing"
          errors=$((errors + 1))
          subdir_ok=false
        elif [ -L "$sdtarget" ] && [ ! -e "$sdtarget" ]; then
          echo "  FAIL: $name/$sdname — broken symlink"
          errors=$((errors + 1))
          subdir_ok=false
        fi
      done
      if [ "$subdir_ok" = true ]; then
        echo "  $_label"
      fi
    fi
  done

  # Check for orphans (symlinks to our repo not in manifest)
  echo ""
  for d in "$SKILLS_TARGET"/*/; do
    [ -d "$d" ] || continue
    local name
    name=$(basename "$d")
    local skill_md="$d/SKILL.md"
    if [ -L "$skill_md" ]; then
      local link
      link=$(readlink "$skill_md" 2>/dev/null || true)
      if [[ "$link" == "$source"/* ]] || [[ "$link" == "$REPO_ROOT"/* ]]; then
        if ! echo "$manifest" | jq -e --arg n "$name" '.skills[$n]' >/dev/null 2>&1; then
          echo "  ORPHAN: $name — symlinks to our repo but not in manifest"
          warnings=$((warnings + 1))
        fi
      fi
    fi
  done

  # Check templates
  local tpl_count
  tpl_count=$(echo "$manifest" | jq '.templates // {} | length')
  if [ "$tpl_count" -gt 0 ]; then
    echo "--- Templates ---"
    for tpl in $(echo "$manifest" | jq -r '.templates // {} | keys[]'); do
      local tpl_file="$TEMPLATES_TARGET/$tpl"
      if [ ! -f "$tpl_file" ]; then
        echo "  FAIL: $tpl — file missing at $tpl_file (run 'skills-deploy install' to restore)"
        errors=$((errors + 1))
      else
        local expected actual
        expected=$(echo "$manifest" | jq -r --arg t "$tpl" '.templates[$t].source_checksum // ""')
        actual=$(file_checksum "$tpl_file")
        if [ -n "$expected" ] && [ "$expected" != "$actual" ] && [ "$expected" != "unknown" ]; then
          echo "  WARN: $tpl — content differs from source (local changes or outdated)"
          warnings=$((warnings + 1))
        else
          echo "  OK: $tpl"
        fi
      fi

      # Check for orphaned owners
      for owner in $(echo "$manifest" | jq -r --arg t "$tpl" '.templates[$t].owners // [] | .[]'); do
        if ! echo "$manifest" | jq -e --arg n "$owner" '.skills[$n]' >/dev/null 2>&1; then
          echo "  WARN: $tpl — owner '$owner' is not an installed skill (orphaned)"
          warnings=$((warnings + 1))
        fi
      done
    done

    # Check for catalog templates not in manifest (for installed skills)
    for name in $(echo "$manifest" | jq -r '.skills // {} | keys[]'); do
      for tpl in $(skill_templates "$name"); do
        if ! echo "$manifest" | jq -e --arg t "$tpl" '.templates[$t]' >/dev/null 2>&1; then
          echo "  WARN: $tpl — declared by $name but not deployed (run 'skills-deploy install' to deploy)"
          warnings=$((warnings + 1))
        fi
      done
    done
    echo ""
  fi

  # Check deployed rules
  if [ -d "$RULES_SRC" ]; then
    echo "--- Rules ---"
    local rules_ok=0 rules_drift=0 rules_missing=0
    for rule_file in "$RULES_SRC"/*.md; do
      [ -f "$rule_file" ] || continue
      local rule_name
      rule_name=$(basename "$rule_file")
      case "$rule_name" in README.md|NOTES.md|DEVELOPMENT.md|CHANGELOG.md) continue ;; esac
      local rule_dst="$RULES_TARGET/$rule_name"
      if [ ! -f "$rule_dst" ]; then
        echo "  MISSING: $rule_name — not deployed (run 'skills-deploy install' to deploy)"
        errors=$((errors + 1))
        rules_missing=$((rules_missing + 1))
      else
        local src_sum dst_sum
        src_sum=$(file_checksum "$rule_file")
        dst_sum=$(file_checksum "$rule_dst")
        if [ "$src_sum" = "$dst_sum" ]; then
          echo "  OK: $rule_name"
          rules_ok=$((rules_ok + 1))
        else
          echo "  WARN: $rule_name — deployed copy differs from source (run 'skills-deploy install' to sync)"
          warnings=$((warnings + 1))
          rules_drift=$((rules_drift + 1))
        fi
      fi
    done
    echo ""
  fi

  echo ""
  local skills_count
  skills_count=$(echo "$manifest" | jq '.skills // {} | length')
  if [ "$errors" -eq 0 ] && [ "$warnings" -eq 0 ]; then
    echo "Health: OK ($skills_count skills, $tpl_count templates installed)"
  else
    echo "Health: $errors errors, $warnings warnings ($skills_count skills, $tpl_count templates)"
  fi
}

# --- main ---

case "${1:-}" in
  install) shift; do_install "$@" ;;
  remove)  shift; do_remove "$@" ;;
  relink)  do_relink ;;
  doctor)  do_doctor ;;
  *)
    echo "Usage: skills-deploy <install|remove|relink|doctor> [options]"
    echo ""
    echo "Commands:"
    echo "  install [skill...] [--no-overwrite]"
    echo "                                    Install skills + templates (all if none specified)."
    echo "                                    Drifted templates and rules are overwritten by default;"
    echo "                                    pass --no-overwrite to preserve deployed copies that differ"
    echo "                                    from source. (--overwrite is accepted as a no-op for"
    echo "                                    backwards compatibility with pre-v1.6 callers.)"
    echo "  remove <skill...>                 Remove skills + templates (--all for all, --force to skip dep check)"
    echo "  relink                            Repair broken/missing symlinks + templates"
    echo "  doctor                            Check installation health (skills + templates)"
    exit 1
    ;;
esac
