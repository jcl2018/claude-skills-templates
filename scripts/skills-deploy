#!/usr/bin/env bash
# skills-deploy — install, remove, relink, and diagnose skills from this repo.
# Usage: skills-deploy <install|remove|relink|doctor> [options]
#   install [--bundle]   F000049/S2 install == clone: ensure a managed git checkout
#                        at ~/.claude/skills/cj-workbench (override SKILLS_DEPLOY_BUNDLE_TARGET)
#                        and symlink the flat /CJ_* skills INTO it. Opt-in; the default
#                        dev-clone install is untouched.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CATALOG="$REPO_ROOT/skills-catalog.json"
# Skills source root is catalog-driven (F000006). Each skill's source dir comes
# from dirname(.files[0]) via skill_source_dir(); skills can live anywhere in
# the repo as long as the catalog points at them.
SKILLS_TARGET="${SKILLS_DEPLOY_TARGET:-$HOME/.claude/skills}"
MANIFEST="${SKILLS_DEPLOY_MANIFEST:-$HOME/.claude/.skills-templates.json}"
TEMPLATES_SRC="$REPO_ROOT/templates"
TEMPLATES_TARGET="${SKILLS_DEPLOY_TEMPLATES_TARGET:-$HOME/.claude/templates}"
RULES_SRC="$REPO_ROOT/rules"
RULES_TARGET="${SKILLS_DEPLOY_RULES_TARGET:-$HOME/.claude/rules}"
# Shared scripts deposit (F000049 / S000085): the shared `scripts/*.sh` helpers
# (+ skills-update-check) travel with the install so the orchestrator-family
# skills resolve them bundle-first instead of reaching a separate source clone
# via `.source`. Deposited to a single `_cj-shared/scripts/` home; the scripts
# already resolve their OWN siblings dirname-relative (BASH_SOURCE), so a
# whole-set deposit keeps every transitive sibling co-located.
SHARED_SCRIPTS_SRC="$REPO_ROOT/scripts"
SHARED_SCRIPTS_TARGET="${SKILLS_DEPLOY_SHARED_SCRIPTS_TARGET:-$HOME/.claude/_cj-shared/scripts}"

# The clobber-safe hook-install primitive + the SENTINEL live in ONE shared,
# sourceable lib (F000069 / S000117) so this script and scripts/setup-hooks.sh
# share a single implementation. Source it repo-local; fall back to the deployed
# _cj-shared copy (defensive — a relocated/managed checkout). Best-effort: if the
# lib is unavailable the gate-hook install becomes a clean no-op (guarded at the
# call sites), never a hard failure of the whole install.
if [ -f "$REPO_ROOT/scripts/cj-hook-lib.sh" ]; then
  # shellcheck source=scripts/cj-hook-lib.sh
  . "$REPO_ROOT/scripts/cj-hook-lib.sh"
elif [ -f "$SHARED_SCRIPTS_TARGET/cj-hook-lib.sh" ]; then
  # shellcheck disable=SC1091
  . "$SHARED_SCRIPTS_TARGET/cj-hook-lib.sh"
fi

# --- helpers ---

require_jq() {
  command -v jq >/dev/null 2>&1 || { echo "ERROR: jq is required" >&2; exit 1; }
}

# Strip CRLF from jq output on Windows (jq.exe writes \r\n). No-op on Unix.
jq() { command jq "$@" | tr -d '\r'; }

manifest_read() {
  [ -f "$MANIFEST" ] && cat "$MANIFEST" || echo '{}'
}

manifest_write() {
  local tmp
  tmp=$(mktemp "${MANIFEST}.tmp.XXXXXX")
  cat > "$tmp"
  mv "$tmp" "$MANIFEST"
}

# List all installable entries: every catalog entry, in catalog order. Catalog
# is the source of truth. Templates-only entries (empty files) are included;
# the install loop handles that branch.
discover_skills() {
  # The default install set EXCLUDES deprecated skills (the F000031 relocation
  # pattern: a deprecated skill's source is archived under deprecated/ and is NOT
  # deployed). An explicit `install <name>` still works for any catalog entry.
  # Matches the `!= deprecated` selector test-deploy.sh's SKILL_COUNT uses.
  [ -f "$CATALOG" ] || return 0
  jq -r '.[] | select((.status // "active") != "deprecated") | .name' "$CATALOG" 2>/dev/null || true
}

# Read skill dependencies from catalog
skill_deps() {
  local name="$1"
  [ -f "$CATALOG" ] || return 0
  jq -r --arg n "$name" '.[] | select(.name == $n) | .depends.skills // [] | .[]' "$CATALOG" 2>/dev/null || true
}

# Read skill status from catalog (active|experimental). Missing = active.
skill_status() {
  local name="$1"
  [ -f "$CATALOG" ] || { echo "active"; return 0; }
  local s
  s=$(jq -r --arg n "$name" '.[] | select(.name == $n) | .status // "active"' "$CATALOG" 2>/dev/null || echo "active")
  [ -n "$s" ] || s="active"
  echo "$s"
}

# Check who owns a skill directory
skill_owner() {
  local name="$1"
  local target="$SKILLS_TARGET/$name/SKILL.md"
  if [ ! -e "$SKILLS_TARGET/$name" ]; then
    echo "none"
  elif [ -L "$target" ]; then
    local link
    link=$(readlink "$target" 2>/dev/null || true)
    case "$link" in
      */skills/gstack/*) echo "gstack" ;;
      "$REPO_ROOT"/*|"$HOME/.claude/skills-templates/"*) echo "ours" ;;
      *) echo "other" ;;
    esac
  else
    echo "manual"
  fi
}

# Reverse dependencies: skills that depend on $1
reverse_deps() {
  local name="$1"
  [ -f "$CATALOG" ] || return 0
  jq -r --arg n "$name" '.[] | select(.depends.skills // [] | index($n)) | .name' "$CATALOG" 2>/dev/null || true
}

# Read templates array for a skill from catalog
skill_templates() {
  local name="$1"
  [ -f "$CATALOG" ] || return 0
  jq -r --arg n "$name" '.[] | select(.name == $n) | .templates // [] | .[]' "$CATALOG" 2>/dev/null || true
}

# Catalog-driven path helpers (F000006). Source root and SKILL.md path come from
# the catalog's files[] array, not hardcoded skills/{name}/. Lets a skill live
# anywhere in the repo as long as the catalog points at it. files[0] is the
# SKILL.md by convention.

# SKILL.md path for a skill (repo-relative). Empty string if skill has no files.
skill_md_path() {
  local name="$1"
  [ -f "$CATALOG" ] || return 0
  jq -r --arg n "$name" '.[] | select(.name == $n) | (.files // []) | .[0] // ""' "$CATALOG" 2>/dev/null || true
}

# Absolute source directory for a skill: dirname of repo-relative files[0].
# Empty string if skill has no files (templates-only entries).
skill_source_dir() {
  local name="$1" f0
  f0=$(skill_md_path "$name")
  if [ -n "$f0" ]; then
    echo "$REPO_ROOT/$(dirname "$f0")"
  fi
}

# Templates source directory base for a skill (repo-relative). Defaults to
# "templates" so existing entries shaped "{skill}/x.md" resolve under
# templates/{skill}/x.md. Override via catalog templates_source field, used
# when the source lives outside templates/.
# When override is set, the entry's basename is joined with the override base.
skill_templates_source() {
  local name="$1"
  [ -f "$CATALOG" ] || { echo "templates"; return 0; }
  local s
  s=$(jq -r --arg n "$name" '.[] | select(.name == $n) | .templates_source // "templates"' "$CATALOG" 2>/dev/null || echo "templates")
  echo "${s:-templates}"
}

# SHA256 of a file (portable: macOS shasum, Linux sha256sum)
file_checksum() {
  (shasum -a 256 "$1" 2>/dev/null || sha256sum "$1" 2>/dev/null) | awk '{print $1}'
}

# Probe whether real symlinks work in $SKILLS_TARGET (S000079). On macOS/Linux/WSL2
# `ln -s` creates a true symlink; on Git Bash `ln -s` copies-by-default (or needs
# Developer Mode/admin), so the probe result drives the install mode. We probe in
# $SKILLS_TARGET itself (not /tmp) because the symlink capability is per-filesystem
# and the target may live on a different mount than $TMPDIR.
# Override: SKILLS_DEPLOY_FORCE_COPY=1 forces "no" (copy-mode) regardless of probe —
# used by tests to exercise copy-mode on a symlink-capable host.
# Echoes "yes" (real symlinks work) or "no" (use copy-mode). Never fails the script.
_can_symlink() {
  if [ "${SKILLS_DEPLOY_FORCE_COPY:-}" = "1" ]; then
    echo "no"
    return 0
  fi
  mkdir -p "$SKILLS_TARGET" 2>/dev/null || true
  local probe_src probe_link result="no"
  probe_src=$(mktemp "$SKILLS_TARGET/.symprobe.src.XXXXXX" 2>/dev/null) || { echo "no"; return 0; }
  probe_link="${probe_src}.lnk"
  rm -f "$probe_link" 2>/dev/null || true
  if ln -s "$probe_src" "$probe_link" 2>/dev/null && [ -L "$probe_link" ]; then
    result="yes"
  fi
  rm -f "$probe_src" "$probe_link" 2>/dev/null || true
  echo "$result"
}

# Validate template name is safe (no path traversal)
# Allows one subfolder level: "CJ_company-workflow/tracker-feature.md"
# Blocks ".." segments to prevent path traversal
validate_template_name() {
  if [[ "$1" =~ ^[a-zA-Z0-9_-]+(/[a-zA-Z0-9_.-]+)?\.md$ ]] && [[ "$1" != *".."* ]]; then
    return 0
  fi
  echo "  ERROR: unsafe template name: $1" >&2
  return 1
}

# --- contract seeding (F000069 / S000116) ---

# Resolve a contract engine for a TARGET repo (F000069 / S000116). Mirrors the
# audit skills' Step-1 resolution PLUS the stale-engine capability probe (Part 1):
#   1. repo-local "$target/scripts/<engine>.sh" — but ONLY if it is CURRENT, proven
#      by the side-effect-free `--classify` probe emitting `GENERATION=`. A repo
#      that vendored an OLD engine (no --classify) would otherwise SHADOW the
#      deployed _cj-shared one and silently no-op every --seed/--classify call.
#   2. the deployed shared home ("$SHARED_SCRIPTS_TARGET/<engine>.sh").
# Echoes the resolved engine path (empty if neither is usable). When the repo-local
# engine is present-but-stale and a _cj-shared engine exists, ALSO emits a
# `STALE_FINDING:` line on stderr naming the engine (the do_seed_contracts caller
# surfaces it as the engine-stale note). `engine` arg is the basename without
# the `.sh` suffix (doc-spec | test-spec | workflow-spec).
resolve_contract_engine() {
  local engine="$1" target="$2"
  local repo_local="$target/scripts/${engine}.sh"
  local shared="$SHARED_SCRIPTS_TARGET/${engine}.sh"
  if [ -x "$repo_local" ]; then
    # Capability probe: a CURRENT engine emits GENERATION= from --classify
    # (read-only). Run it with REPO_ROOT pinned to the target so the probe reads
    # the target's tree, not the workbench's.
    local gen
    gen=$(REPO_ROOT="$target" bash "$repo_local" --classify 2>/dev/null | awk -F= '/^GENERATION=/{print $1}')
    if [ "$gen" = "GENERATION" ]; then
      echo "$repo_local"
      return 0
    fi
    # Stale repo-local engine: fall back to _cj-shared if usable, and report it.
    if [ -x "$shared" ]; then
      echo "STALE_FINDING: stage1/engine-stale — repo-local ${engine}.sh is stale (missing --classify); using _cj-shared. Remedy: update/remove the vendored scripts/${engine}.sh or re-run 'skills-deploy install'." >&2
      echo "$shared"
      return 0
    fi
    # No usable _cj-shared fallback — the stale repo-local is all there is.
    echo "STALE_FINDING: stage1/engine — repo-local ${engine}.sh is stale (missing --classify) and no _cj-shared ${engine}.sh is available; cannot seed ${engine}." >&2
    echo ""
    return 0
  fi
  if [ -x "$shared" ]; then
    echo "$shared"
    return 0
  fi
  echo ""
}

# Detect whether a TARGET repo IS the workbench self-repo (F000069 / S000116 —
# the DATA-LOSS guard). Seeding must NEVER fire on the workbench's own checkout:
# it AUTHORS the canonical contracts, and re-seeding with skeletons is data loss.
# Two INDEPENDENT signals, OR'd (a false negative is the catastrophic case, so we
# err toward "self"):
#   (1) PRIMARY — the target's MAIN repo toplevel == the manifest `source` /
#       `bundle_path`. We resolve the MAIN toplevel via the git-common-dir parent
#       (the same idiom do_install uses) so a git WORKTREE of the workbench (whose
#       own `--show-toplevel` differs from `source`) is still correctly detected
#       as self.
#   (2) SECONDARY — the target carries a canonical (non-skeleton) custom overlay
#       (`spec/doc-spec-custom.md` or `spec/test-spec-custom.md`) AND a root
#       `skills-catalog.json`. The general seed files are byte-identical to
#       `--seed`, so an AUTHORED contract overlay plus the catalog marks the
#       workbench. The skills-catalog.json gate is what distinguishes the workbench
#       from a CONSUMER that hand-authored its own overlay (a consumer never ships a
#       skills-catalog.json) — without it, overlay presence alone false-positived
#       real consumers and skipped their adoption + gate-hook install.
# Echoes "yes" (self-repo — skip) or "no". Never fails.
is_workbench_self_repo() {
  local target="$1"
  # (1) manifest-source match (worktree-aware).
  local m msrc mbundle main_top
  m=$(manifest_read 2>/dev/null || echo '{}')
  msrc=$(echo "$m" | jq -r '.source // empty' 2>/dev/null || echo "")
  mbundle=$(echo "$m" | jq -r '.bundle_path // empty' 2>/dev/null || echo "")
  main_top=$(dirname "$(git -C "$target" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" 2>/dev/null) || true
  if [ -z "$main_top" ] || [ ! -d "$main_top" ]; then
    main_top="$target"
  fi
  if [ -n "$msrc" ] && [ "$main_top" = "$msrc" ]; then echo "yes"; return 0; fi
  if [ -n "$mbundle" ] && [ "$main_top" = "$mbundle" ]; then echo "yes"; return 0; fi
  # (2) canonical-contract presence (a HAND-AUTHORED custom overlay = an AUTHORED
  # contract → self-repo). EXCLUDE the auto-generated adoption overlay (S000117):
  # `complete_consumer_adoption` writes a spec/doc-spec-custom.md carrying the
  # `auto-generated by skills-deploy` marker into a CONSUMER repo — that overlay is
  # an adoption artifact, NOT an authored contract, so it must NOT make the consumer
  # look like the workbench self-repo (which would block the gate-hook install + the
  # next adoption). A doc overlay counts as "authored" only WITHOUT that marker.
  #
  # GATE on skills-catalog.json (D-fix): a CONSUMER repo can legitimately
  # hand-author its own spec/doc-spec-custom.md or spec/test-spec-custom.md overlay
  # (the documented way to declare repo-specific docs/units), so overlay presence
  # alone is too broad — it false-positived real consumers and skipped their entire
  # adoption + gate-hook install. The unmistakable workbench marker a consumer never
  # ships is skills-catalog.json at the repo root, so signals (2) and (3) only fire
  # when it is present. The real workbench carries skills-catalog.json + its authored
  # overlays (still "yes" — data-loss protection preserved); a consumer with a
  # curated overlay but no catalog now returns "no" (adoption proceeds). Signal (1)
  # (the manifest source/bundle_path match) is the primary identifier, unchanged.
  if [ -f "$target/skills-catalog.json" ]; then
    local _auto_marker='auto-generated by skills-deploy'
    if [ -f "$target/spec/doc-spec-custom.md" ] \
       && ! grep -qF "$_auto_marker" "$target/spec/doc-spec-custom.md" 2>/dev/null; then
      echo "yes"; return 0
    fi
    if [ -f "$target/spec/test-spec-custom.md" ]; then
      echo "yes"; return 0
    fi
  fi
  echo "no"
}

# Force-seed the three contracts into a TARGET repo (F000069 / S000116). The
# single shared seeding routine all three triggers call. For each of doc-spec,
# test-spec, workflow-spec: resolve the engine (repo-local→stale-probe→_cj-shared),
# and if `spec/<contract>.md` is ABSENT, seed it CORRUPTION-GUARDED (write a temp,
# require non-empty AND `--validate`-clean — with REPO_ROOT pinned to the target so
# the validate reads the target's tree — then `mv` into place). Idempotent: a
# present contract is skipped. NEVER touches the workbench self-repo (data-loss
# guard). Prints a per-contract line (seeded | present | seed-failed) + a summary.
# Usage: do_seed_contracts [--repo <path>]
do_seed_contracts() {
  require_jq
  local target=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo) target="${2:-}"; shift 2 ;;
      *) shift ;;
    esac
  done
  [ -n "$target" ] || target="$(pwd)"

  # Git-repo guard: seeding only makes sense inside a git repo (the contracts live
  # at a repo's `spec/`). A non-git target is a clean no-op.
  if ! git -C "$target" rev-parse --show-toplevel >/dev/null 2>&1; then
    echo "  SEED: $target is not a git repository — nothing to seed (no-op)"
    return 0
  fi
  # Normalize to the target's own toplevel so `spec/` lands at the repo root.
  target=$(git -C "$target" rev-parse --show-toplevel 2>/dev/null)

  # DATA-LOSS GUARD (primary): never seed the workbench self-repo.
  if [ "$(is_workbench_self_repo "$target")" = "yes" ]; then
    echo "  SEED: $target is the workbench self-repo (authors the canonical contracts) — skipping all seeding (data-loss guard)"
    return 0
  fi

  local seeded=0 present=0 failed=0
  local engine_basename
  for engine_basename in doc-spec test-spec workflow-spec; do
    local spec_file="$target/spec/${engine_basename}.md"
    if [ -f "$spec_file" ]; then
      echo "  ${engine_basename}: present"
      present=$((present + 1))
      continue
    fi
    # Resolve the engine (repo-local→stale-probe→_cj-shared). The resolver writes
    # any STALE_FINDING: line to stderr; capture it to a temp so it surfaces
    # alongside the contract line (rather than racing to the terminal).
    local engine stale_finding="" stale_tmp
    stale_tmp=$(mktemp)
    engine=$(resolve_contract_engine "$engine_basename" "$target" 2>"$stale_tmp")
    stale_finding=$(cat "$stale_tmp" 2>/dev/null || true)
    rm -f "$stale_tmp" 2>/dev/null || true
    [ -n "$stale_finding" ] && echo "  $stale_finding"
    if [ -z "$engine" ]; then
      echo "  ${engine_basename}: seed-failed (no usable engine — repo-local stale + _cj-shared absent)"
      failed=$((failed + 1))
      continue
    fi
    # Corruption-guarded seed: temp → non-empty AND --validate-clean → mv.
    # REPO_ROOT pinned to the target so the validate reads the target's tree
    # (e.g. workflow-spec's no-vanish check is vacuous in a no-catalog consumer).
    local tmp_dir tmp_file
    tmp_dir=$(mktemp -d)
    tmp_file="$tmp_dir/${engine_basename}.md"
    local path_var
    case "$engine_basename" in
      doc-spec) path_var="DOC_SPEC_PATH" ;;
      test-spec) path_var="TEST_SPEC_PATH" ;;
      workflow-spec) path_var="WORKFLOW_SPEC_PATH" ;;
    esac
    if REPO_ROOT="$target" bash "$engine" --seed > "$tmp_file" 2>/dev/null \
       && [ -s "$tmp_file" ] \
       && REPO_ROOT="$target" env "$path_var=$tmp_file" bash "$engine" --validate >/dev/null 2>&1; then
      mkdir -p "$target/spec"
      mv "$tmp_file" "$spec_file"
      echo "  ${engine_basename}: seeded"
      seeded=$((seeded + 1))
    else
      echo "  ${engine_basename}: seed-failed (--seed empty or --validate-dirty; spec/ left untouched)"
      failed=$((failed + 1))
    fi
    rm -rf "$tmp_dir" 2>/dev/null || true
  done

  echo "  SEED summary ($target): seeded=$seeded present=$present seed-failed=$failed"
  return 0
}

# Complete consumer adoption (F000069 / S000117): make a freshly-seeded consumer
# CONTRACT-CLEAN so the FULLY-HARD gate passes from its first commit (instead of
# softening the gate). Two idempotent, deterministic steps, run AFTER seeding +
# BEFORE the gate-hook install, in the consumer-path block:
#
#   (b) AUTO-REFRESH the generated surfaces — render docs/test-catalog.md +
#       docs/tests/ (test-spec) and docs/workflow.md + docs/workflows/ (workflow-spec)
#       from the seeded registries, so the render-freshness checks pass. Engines
#       resolve repo-local→stale-probe→_cj-shared (resolve_contract_engine). Run
#       FIRST so step (a) can declare exactly what the render produced.
#   (a) AUTO-DECLARE the repo-specific generated/seeded docs — write a minimal
#       spec/doc-spec-custom.md overlay declaring every undeclared docs/**/*.md +
#       spec/*.md orphan the engine reports (so doc-spec --check-on-disk's `orphans`
#       check passes), validate the MERGED registry, and ROLL BACK if invalid (never
#       leave a broken overlay).
#
# A target that carries a HAND-AUTHORED spec/doc-spec-custom.md (one WITHOUT our
# marker) is ALSO completed — APPEND-ONLY, without clobbering the user's curation
# (D000037): step (b) re-renders the generated surfaces (those are not curation, so
# (re)writing them is always safe), and step (a) APPENDS one declaring row per NEW
# undeclared orphan to the overlay's existing table — preserving every existing row
# and any prose/header the user wrote — then validates the merged registry and rolls
# the append back if invalid. The hand-authored overlay is NEVER regenerated (that
# would lose curation); only the auto-marked / absent overlay is regenerated wholesale.
# This keeps the "never bricks a fresh adopter" guarantee even for a repo that
# hand-authored its overlay BEFORE turnkey-adoption existed.
#
# The workbench self-repo never reaches here (the caller gates on
# is_workbench_self_repo). Never the data-loss path: the auto-marked/absent overlay
# is regenerated (it owns it), the hand-authored overlay is only appended to. Prints
# one line per step. Always returns 0 (best-effort).
# Shared step (b): re-render the generated doc surfaces (test-catalog + workflow
# docs) from the seeded registries so the render-freshness checks pass. Generated
# files are NOT curation, so (re)writing them is always safe — used by BOTH the
# owned-overlay and the hand-authored-overlay adoption paths. Echoes the count of
# successfully-refreshed surfaces. Best-effort.
# Usage: _adopt_refresh_surfaces <target-repo>
_adopt_refresh_surfaces() {
  local target="$1"
  local refreshed=0 eng engine_path stale_tmp
  for eng in test-spec workflow-spec; do
    stale_tmp=$(mktemp)
    engine_path=$(resolve_contract_engine "$eng" "$target" 2>"$stale_tmp")
    rm -f "$stale_tmp" 2>/dev/null || true
    if [ -n "$engine_path" ]; then
      if REPO_ROOT="$target" bash "$engine_path" --render-docs >/dev/null 2>&1; then
        refreshed=$((refreshed + 1))
      fi
    fi
  done
  echo "$refreshed"
}

# Map an orphan path to its declaring-row Purpose cell (shared by the owned-overlay
# regenerate and the hand-authored APPEND paths).
# Usage: _adopt_purpose_for <path>
_adopt_purpose_for() {
  case "$1" in
    spec/workflow-spec.md)            echo "The workflow-docs registry (seeded; renders docs/workflow.md + docs/workflows/)." ;;
    spec/doc-spec-custom.md)          echo "This overlay — the repo-specific doc registry." ;;
    docs/test-catalog.md|docs/tests/*) echo "Generated test catalog surface (from spec/test-spec.md via test-spec.sh --render-docs)." ;;
    docs/workflow.md|docs/workflows/*) echo "Generated workflow surface (from spec/workflow-spec.md via workflow-spec.sh --render-docs)." ;;
    *)                                echo "Repo-specific seeded/generated doc (auto-declared by skills-deploy adoption)." ;;
  esac
}

# Usage: complete_consumer_adoption <target-repo>
complete_consumer_adoption() {
  local target="$1"
  target=$(git -C "$target" rev-parse --show-toplevel 2>/dev/null) || return 0
  local overlay="$target/spec/doc-spec-custom.md"
  local overlay_marker='# doc-spec-custom.md — auto-generated by skills-deploy (S000117 adoption)'

  # Hand-authored-overlay path (D000037): a spec/doc-spec-custom.md WITHOUT our
  # marker is the user's curated registry. Complete adoption WITHOUT clobbering it —
  # re-render the generated surfaces, then APPEND-ONLY-declare the new orphans,
  # preserving every existing row + the user's prose/header.
  if [ -f "$overlay" ] && ! grep -qF "$overlay_marker" "$overlay" 2>/dev/null; then
    complete_consumer_adoption_handauthored "$target" "$overlay"
    return 0
  fi

  # (b) AUTO-REFRESH the generated surfaces (test-catalog + workflow docs).
  local refreshed
  refreshed=$(_adopt_refresh_surfaces "$target")
  echo "  ADOPT: refreshed $refreshed generated doc surface(s) (test-catalog + workflow docs)"

  # (a) AUTO-DECLARE every orphan the doc-spec engine now reports. Resolve the
  # doc-spec engine, run --check-on-disk, parse the `(orphan): <path>` lines, and
  # append a declaring row for each not-already-declared path into our owned overlay.
  local doc_engine doc_stale
  doc_stale=$(mktemp)
  doc_engine=$(resolve_contract_engine "doc-spec" "$target" 2>"$doc_stale")
  rm -f "$doc_stale" 2>/dev/null || true
  if [ -z "$doc_engine" ]; then
    echo "  ADOPT: no usable doc-spec engine — skipping auto-declare (orphans may remain)"
    return 0
  fi

  # Collect orphan paths (docs/**/*.md + spec/*.md the merged registry doesn't declare).
  local orphans
  orphans=$(REPO_ROOT="$target" bash "$doc_engine" --check-on-disk 2>/dev/null \
    | grep -E '^FINDING: stage1/orphans' | sed -E 's/.*\(orphan\): //' | sort -u || true)
  # The overlay itself will exist after we write it — declare it too (self-declaration)
  # so it is not an orphan on the next check. Build the full set to declare.
  local to_declare
  to_declare=$(printf '%s\n' "$orphans" "spec/doc-spec-custom.md" | sed '/^$/d' | sort -u)

  if [ -z "$to_declare" ]; then
    echo "  ADOPT: no undeclared generated/seeded docs to declare (registry already clean)"
    return 0
  fi

  # Build the overlay (header + a 3-col table). If our overlay already exists, MERGE:
  # keep its declared paths, add any new ones. Simplest robust form: regenerate the
  # overlay declaring the union of (existing-declared-in-our-overlay) + (to_declare).
  local existing=""
  if [ -f "$overlay" ]; then
    existing=$(grep -E '^\| ' "$overlay" 2>/dev/null | grep -vE '^\| *Doc *\|' | grep -vE '^\|[ -]+\|' \
      | sed -E 's/^\| *//; s/ *\|.*//' | sed '/^$/d' || true)
  fi
  local all_paths
  all_paths=$(printf '%s\n' "$existing" "$to_declare" | sed '/^$/d' | sort -u)

  local tmp_overlay
  tmp_overlay=$(mktemp)
  {
    echo "$overlay_marker"
    echo "# repo-specific doc registry overlay. Declares the seeded contracts +"
    echo "# generated surfaces so the deterministic contract gate passes. Re-run"
    echo "# 'skills-deploy install' (or install-contract-gate) regenerates it; replace"
    echo "# it with a hand-authored overlay to take ownership (this tool then skips it)."
    echo ""
    echo "| Doc | Purpose | Requirement |"
    echo "|-----|---------|-------------|"
    local p purpose
    while IFS= read -r p; do
      [ -n "$p" ] || continue
      purpose=$(_adopt_purpose_for "$p")
      printf '| %s | %s | Present; auto-declared by skills-deploy adoption. |\n' "$p" "$purpose"
    done <<EOF
$all_paths
EOF
  } > "$tmp_overlay"

  # Install atomically, then VALIDATE the merged registry; roll back on failure.
  mkdir -p "$target/spec"
  local backup=""
  if [ -f "$overlay" ]; then
    backup=$(mktemp)
    cp -p "$overlay" "$backup"
  fi
  mv "$tmp_overlay" "$overlay"
  if REPO_ROOT="$target" bash "$doc_engine" --validate >/dev/null 2>&1; then
    echo "  ADOPT: declared $(printf '%s\n' "$all_paths" | sed '/^$/d' | wc -l | tr -d ' ') repo-specific doc(s) in spec/doc-spec-custom.md (merged registry validates)"
    if [ -n "$backup" ]; then rm -f "$backup"; fi
  else
    # Roll back — never leave a broken overlay.
    if [ -n "$backup" ]; then
      mv "$backup" "$overlay"
    else
      rm -f "$overlay"
    fi
    echo "  ADOPT: auto-declare produced an invalid merged registry — rolled back (spec/doc-spec-custom.md left as before)"
  fi
  return 0
}

# Hand-authored-overlay adoption path (D000037). Completes a consumer that
# hand-authored its spec/doc-spec-custom.md BEFORE turnkey-adoption existed, WITHOUT
# clobbering the user's curation:
#   (b) re-render the generated surfaces (test-catalog + workflow docs) — safe, not
#       curation.
#   (a) APPEND-ONLY one declaring row per NEW undeclared orphan to the overlay's
#       existing table, preserving every existing row + the user's prose/header. The
#       overlay is NEVER regenerated. Then validate the merged registry and ROLL BACK
#       the append (restore the pre-append file) if invalid.
# Prints clear ADOPT: lines. Always returns 0 (best-effort).
# Usage: complete_consumer_adoption_handauthored <target-repo> <overlay-path>
complete_consumer_adoption_handauthored() {
  local target="$1" overlay="$2"

  # (b) Re-render the generated surfaces (generated files are not curation).
  local refreshed
  refreshed=$(_adopt_refresh_surfaces "$target")

  # (a) Resolve the doc-spec engine; collect orphans; append only the NOT-already-
  # declared ones to the hand-authored overlay's existing table.
  local doc_engine doc_stale
  doc_stale=$(mktemp)
  doc_engine=$(resolve_contract_engine "doc-spec" "$target" 2>"$doc_stale")
  rm -f "$doc_stale" 2>/dev/null || true
  if [ -z "$doc_engine" ]; then
    echo "  ADOPT: hand-authored overlay — refreshed $refreshed surface(s); no usable doc-spec engine, skipping append-declare (orphans may remain)"
    return 0
  fi

  # Orphan paths the merged registry doesn't declare (includes the overlay file
  # itself if the user didn't self-declare it).
  local orphans
  orphans=$(REPO_ROOT="$target" bash "$doc_engine" --check-on-disk 2>/dev/null \
    | grep -E '^FINDING: stage1/orphans' | sed -E 's/.*\(orphan\): //' | sort -u || true)

  # Paths ALREADY declared in the user's overlay (first table column), so we only
  # APPEND genuinely-new ones — never duplicate a curated row.
  local already
  already=$(grep -E '^\| ' "$overlay" 2>/dev/null | grep -vE '^\| *Doc *\|' | grep -vE '^\|[ -]+\|' \
    | sed -E 's/^\| *//; s/ *\|.*//' | sed '/^$/d' | sort -u || true)

  # Set difference: orphans NOT already declared.
  local to_append
  to_append=$(comm -23 \
    <(printf '%s\n' "$orphans" | sed '/^$/d' | sort -u) \
    <(printf '%s\n' "$already" | sed '/^$/d' | sort -u) || true)

  if [ -z "$to_append" ]; then
    echo "  ADOPT: hand-authored overlay — refreshed $refreshed surface(s); no new orphans to declare (curated rows preserved)"
    return 0
  fi

  # Build the new declaring rows into a temp file (one per NEW orphan).
  local rows_tmp p purpose appended=0
  rows_tmp=$(mktemp)
  while IFS= read -r p; do
    [ -n "$p" ] || continue
    purpose=$(_adopt_purpose_for "$p")
    printf '| %s | %s | Present; auto-declared by skills-deploy adoption. |\n' "$p" "$purpose" >> "$rows_tmp"
    appended=$((appended + 1))
  done <<EOF
$to_append
EOF

  # Back up the user's file, then SPLICE the new rows in IMMEDIATELY AFTER the last
  # Markdown table-data row (a `^\s*|` line), so they stay CONTIGUOUS with the
  # curated registry table under its existing `| Doc | Purpose | Requirement |`
  # header — never after a trailing `<!-- ...END -->` comment or prose, where the
  # parser (registry = the canonical table; rows must be contiguous under the header)
  # would drop them. If the overlay somehow has no table row, fall back to appending
  # at EOF. Every existing byte/row/prose line is preserved.
  local backup
  backup=$(mktemp)
  cp -p "$overlay" "$backup"

  local last_row_ln spliced_tmp
  last_row_ln=$(grep -nE '^[[:space:]]*\|' "$overlay" 2>/dev/null | tail -1 | cut -d: -f1 || true)
  spliced_tmp=$(mktemp)
  if [ -n "$last_row_ln" ]; then
    # Lines 1..last_row_ln, then the new rows, then the remainder (END comment/prose).
    {
      sed -n "1,${last_row_ln}p" "$overlay"
      cat "$rows_tmp"
      sed -n "$((last_row_ln + 1)),\$p" "$overlay"
    } > "$spliced_tmp"
  else
    # No table row found — fall back to EOF append (ensure a fresh line first).
    cp "$overlay" "$spliced_tmp"
    if [ -n "$(tail -c1 "$spliced_tmp" 2>/dev/null)" ]; then printf '\n' >> "$spliced_tmp"; fi
    cat "$rows_tmp" >> "$spliced_tmp"
  fi
  mv "$spliced_tmp" "$overlay"
  rm -f "$rows_tmp"

  if REPO_ROOT="$target" bash "$doc_engine" --validate >/dev/null 2>&1; then
    echo "  ADOPT: hand-authored overlay — refreshed $refreshed surface(s) + appended $appended new declaration(s), curated rows preserved (merged registry validates)"
    rm -f "$backup"
  else
    # Roll back the append — never leave a broken overlay; the user's file is restored.
    mv "$backup" "$overlay"
    echo "  ADOPT: hand-authored overlay — append produced an invalid merged registry, rolled back the append (curated overlay left as before; refreshed $refreshed surface(s))"
  fi
  return 0
}

# --- contract-gate pre-commit hook (F000069 / S000117) ---

# The body of the consumer pre-commit hook. It resolves cj-contract-gate.sh from
# the deployed _cj-shared home at commit time and runs it; a non-zero exit (a HARD
# contract finding) blocks the commit. Carries the shared SENTINEL so a re-install
# is idempotent (refresh-in-place) and `--remove` recognizes it. Heredoc is
# 'GATEHOOK'-quoted: NO variable expands here — $CJ_SHARED_SCRIPTS / $REPO_ROOT
# resolve at COMMIT time, in the consumer's shell, not at install time.
gate_hook_body() {
  cat <<'GATEHOOK'
#!/usr/bin/env bash
# Auto-installed by scripts/setup-hooks.sh
# cj-contract-gate consumer pre-commit hook (F000069 / S000117). Runs the
# deterministic, agent-free Stage-1 contract gate; a HARD contract finding (a
# stale generated catalog, an unregistered tests/*.test.sh, a malformed registry,
# a no-vanish gap) blocks the commit. A missing DECLARED doc is a SOFT remediation
# (run /CJ_document-release) and does NOT block. An unadopted contract is a clean
# SKIP. Opt out: skills-deploy install-contract-gate --remove (or git commit
# --no-verify for a one-off).
_GATE="${CJ_SHARED_SCRIPTS:-$HOME/.claude/_cj-shared/scripts}/cj-contract-gate.sh"
if [ -x "$_GATE" ]; then
  REPO="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
  bash "$_GATE" --repo "$REPO" --quiet || {
    echo "" >&2
    echo "cj-contract-gate: commit BLOCKED by a hard contract finding (see above)." >&2
    echo "  Fix the finding, or 'git commit --no-verify' to bypass for a one-off." >&2
    exit 1
  }
fi
exit 0
GATEHOOK
}

# --- vendored gate + CI workflow (F000089 / S000138) ---

# The 4 gate engines vendored into a consumer's .cj-contract/ so the gate is
# self-contained on a bare CI runner (no ~/.claude/_cj-shared). The gate resolves
# its 3 sibling engines from its OWN dir as a last resort, so co-locating all 4
# under one dir makes `bash .cj-contract/cj-contract-gate.sh --repo .` work with
# nothing installed.
CJ_VENDOR_DIR=".cj-contract"
CJ_VENDOR_SCRIPTS="cj-contract-gate.sh doc-spec.sh test-spec.sh workflow-spec.sh"
# The sentinel that marks a workbench-OWNED vendored copy / CI drop. Prepended to
# each vendored script + the workflow so `--remove` + drift-detection recognize an
# unmodified auto-vendored file (a hand-edited one — sentinel stripped — is left
# untouched, symmetric with the hook's foreign-file protection).
CJ_VENDOR_SENTINEL="# vendored from claude-skills-templates by skills-deploy install-contract-gate"

# Read the workbench collection version for the vendor stamp. Repo-local VERSION
# (running from the workbench) → the manifest source's VERSION → "unknown".
cj_vendor_version() {
  if [ -f "$REPO_ROOT/VERSION" ]; then
    tr -d '[:space:]' < "$REPO_ROOT/VERSION"; return 0
  fi
  local m msrc
  m=$(manifest_read 2>/dev/null || echo '{}')
  msrc=$(echo "$m" | jq -r '.source // empty' 2>/dev/null || echo "")
  if [ -n "$msrc" ] && [ -f "$msrc/VERSION" ]; then
    tr -d '[:space:]' < "$msrc/VERSION"; return 0
  fi
  echo "unknown"
}

# Resolve the SOURCE dir the 4 gate scripts are copied FROM. Repo-local scripts/
# when running inside the workbench checkout, else the deployed _cj-shared home
# (the same resolution the update-check / gate use). Echoes the dir (empty if
# neither carries the gate).
cj_vendor_source_dir() {
  if [ -x "$SHARED_SCRIPTS_SRC/cj-contract-gate.sh" ]; then
    echo "$SHARED_SCRIPTS_SRC"; return 0
  fi
  if [ -x "$SHARED_SCRIPTS_TARGET/cj-contract-gate.sh" ]; then
    echo "$SHARED_SCRIPTS_TARGET"; return 0
  fi
  echo ""
}

# The CI-workflow body, emitted from an embedded heredoc (mirrors gate_hook_body).
# 'CIGATE'-quoted: nothing expands here — it is a static YAML template. The
# sentinel comment marks it workbench-auto-dropped so `--remove` + the
# hand-authored-protection check can recognize an unmodified auto-drop.
ci_workflow_body() {
  cat <<'CIGATE'
# vendored from claude-skills-templates by skills-deploy install-contract-gate — re-run to re-sync; do not hand-edit
name: Contract Gate
on:
  pull_request:
  push:
    branches: [main]
jobs:
  contract-gate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Install jq
        run: sudo apt-get update && sudo apt-get install -y jq
      - name: Run the deterministic contract gate
        run: bash .cj-contract/cj-contract-gate.sh --repo .
CIGATE
}

# Vendor the 4 gate engines into <target>/.cj-contract/, GUARDED (F000089/S000138).
# For each script: prepend the sentinel + version stamp header, LF-normalize the
# body, write, chmod +x. Overwrite by default (sync semantics). Guards mirror the
# hook install: non-git → no-op, workbench-self → SKIP, no usable source → note.
# Echoes VENDOR: outcome lines. Always returns 0 (best-effort; never halts).
# Usage: vendor_gate_engines <target-repo>
vendor_gate_engines() {
  local target="$1"
  if ! git -C "$target" rev-parse --show-toplevel >/dev/null 2>&1; then
    echo "  VENDOR: $target is not a git repository — nothing to vendor (no-op)"
    return 0
  fi
  target=$(git -C "$target" rev-parse --show-toplevel 2>/dev/null)
  if [ "$(is_workbench_self_repo "$target")" = "yes" ]; then
    echo "  VENDOR: $target is the workbench self-repo (authors the engines) — skipping vendor"
    return 0
  fi
  local src
  src=$(cj_vendor_source_dir)
  if [ -z "$src" ]; then
    echo "  VENDOR: no usable source for the gate engines (repo-local scripts/ + _cj-shared absent) — skipping vendor"
    return 0
  fi
  local ver
  ver=$(cj_vendor_version)
  local dest="$target/$CJ_VENDOR_DIR"
  mkdir -p "$dest" 2>/dev/null || true
  local script vendored=0 missing=0
  for script in $CJ_VENDOR_SCRIPTS; do
    if [ ! -f "$src/$script" ]; then
      echo "  VENDOR: source $script not found under $src — skipping it"
      missing=$((missing + 1))
      continue
    fi
    local out="$dest/$script"
    {
      echo "$CJ_VENDOR_SENTINEL v$ver — re-run 'skills-deploy install-contract-gate' to re-sync; do not hand-edit"
      # LF-normalize the source body (strip any CR) so the vendored copy is LF.
      tr -d '\r' < "$src/$script"
    } > "$out"
    chmod +x "$out" 2>/dev/null || true
    vendored=$((vendored + 1))
  done
  echo "  VENDOR: vendored $vendored gate engine(s) into $CJ_VENDOR_DIR/ (stamped v$ver, LF, +x)$([ "$missing" -gt 0 ] && echo " — $missing source(s) missing")"
  return 0
}

# Drop the CI workflow into <target>/.github/workflows/cj-contract-gate.yml,
# GUARDED (F000089/S000138). Skip-with-note if a hand-authored (non-sentinel)
# workflow of that name already exists; overwrite only a prior sentinel auto-drop.
# Guards mirror vendor: non-git → no-op, workbench-self → SKIP. Echoes CI-TEMPLATE:
# outcome lines. Always returns 0 (best-effort; never halts).
# Usage: drop_ci_workflow <target-repo>
drop_ci_workflow() {
  local target="$1"
  if ! git -C "$target" rev-parse --show-toplevel >/dev/null 2>&1; then
    echo "  CI-TEMPLATE: $target is not a git repository — nothing to drop (no-op)"
    return 0
  fi
  target=$(git -C "$target" rev-parse --show-toplevel 2>/dev/null)
  if [ "$(is_workbench_self_repo "$target")" = "yes" ]; then
    echo "  CI-TEMPLATE: $target is the workbench self-repo — skipping CI-workflow drop"
    return 0
  fi
  local wf="$target/.github/workflows/cj-contract-gate.yml"
  if [ -f "$wf" ] && ! grep -qF "$CJ_VENDOR_SENTINEL" "$wf" 2>/dev/null; then
    echo "  CI-TEMPLATE: $wf exists and is hand-authored (no sentinel) — left untouched (skip-with-note)"
    return 0
  fi
  mkdir -p "$target/.github/workflows" 2>/dev/null || true
  ci_workflow_body > "$wf"
  echo "  CI-TEMPLATE: dropped .github/workflows/cj-contract-gate.yml (runs the vendored gate on pull_request + push:main)"
  return 0
}

# Remove the vendored .cj-contract/ + the dropped CI workflow, SENTINEL-GATED
# (F000089/S000138) — symmetric with the hook removal. A vendored script or the
# workflow is deleted ONLY when it carries the workbench sentinel (unmodified /
# auto-vendored); a hand-edited file (sentinel stripped) is left UNTOUCHED. The
# .cj-contract/ dir is removed only when every remaining file was sentinel-owned
# (so it is empty after the sweep). Echoes VENDOR:/CI-TEMPLATE: outcome lines.
# Usage: remove_vendored_gate <target-repo>
remove_vendored_gate() {
  local target="$1"
  target=$(git -C "$target" rev-parse --show-toplevel 2>/dev/null || echo "$target")
  local dest="$target/$CJ_VENDOR_DIR"
  if [ -d "$dest" ]; then
    local script removed=0 kept=0
    for script in $CJ_VENDOR_SCRIPTS; do
      local f="$dest/$script"
      [ -f "$f" ] || continue
      if grep -qF "$CJ_VENDOR_SENTINEL" "$f" 2>/dev/null; then
        rm -f "$f" 2>/dev/null || true
        removed=$((removed + 1))
      else
        kept=$((kept + 1))
      fi
    done
    # Remove the dir only if nothing (sentinel-owned or foreign) remains in it.
    if [ -z "$(ls -A "$dest" 2>/dev/null)" ]; then
      rmdir "$dest" 2>/dev/null || true
      echo "  VENDOR: removed $CJ_VENDOR_DIR/ ($removed vendored engine(s) deleted)"
    else
      echo "  VENDOR: deleted $removed sentinel-owned engine(s); kept $kept hand-edited/foreign file(s) — $CJ_VENDOR_DIR/ left in place"
    fi
  else
    echo "  VENDOR: no $CJ_VENDOR_DIR/ to remove (no-op)"
  fi
  local wf="$target/.github/workflows/cj-contract-gate.yml"
  if [ -f "$wf" ]; then
    if grep -qF "$CJ_VENDOR_SENTINEL" "$wf" 2>/dev/null; then
      rm -f "$wf" 2>/dev/null || true
      echo "  CI-TEMPLATE: removed .github/workflows/cj-contract-gate.yml (sentinel auto-drop)"
    else
      echo "  CI-TEMPLATE: .github/workflows/cj-contract-gate.yml is hand-authored (no sentinel) — left untouched"
    fi
  else
    echo "  CI-TEMPLATE: no cj-contract-gate.yml to remove (no-op)"
  fi
  return 0
}

# Install the contract-gate pre-commit hook into a TARGET repo, GUARDED
# (F000069 / S000117). Reuses the shared cj_install_hook safety (sentinel-aware
# idempotent; back-up-a-non-workbench-hook-with-a-WARN). Guards, in order:
#   - non-git cwd            → clean no-op (note)
#   - shared lib unavailable → clean no-op (note; never a hard failure)
#   - workbench self-repo    → SKIP (it runs validate.sh — no double-enforcement)
#   - custom core.hooksPath  → SKIP with a note (husky/lefthook — do not fight it)
# Echoes one outcome line. Always returns 0 (best-effort; never halts an install).
# Usage: install_contract_gate_hook <target-repo>
install_contract_gate_hook() {
  local target="$1"
  # Git-repo guard: a non-git target is a clean no-op.
  if ! git -C "$target" rev-parse --show-toplevel >/dev/null 2>&1; then
    echo "  GATE-HOOK: $target is not a git repository — nothing to install (no-op)"
    return 0
  fi
  target=$(git -C "$target" rev-parse --show-toplevel 2>/dev/null)
  # Shared-lib guard: cj_install_hook must be available (sourced at startup).
  if ! command -v cj_install_hook >/dev/null 2>&1; then
    echo "  GATE-HOOK: shared hook lib unavailable — skipping gate-hook install (no-op)"
    return 0
  fi
  # Workbench self-repo: it enforces its contract via validate.sh — no double-enforce.
  if [ "$(is_workbench_self_repo "$target")" = "yes" ]; then
    echo "  GATE-HOOK: $target is the workbench self-repo (runs validate.sh) — skipping gate-hook install"
    return 0
  fi
  # Custom core.hooksPath (husky/lefthook/pre-commit-framework): do not fight a
  # committed hooks dir — SKIP with a note (the standalone --remove is the opt-out).
  local custom_hp
  if custom_hp=$(cj_has_custom_hookspath "$target"); then
    echo "  GATE-HOOK: $target sets a custom core.hooksPath ($custom_hp) — skipping (use 'install-contract-gate' explicitly if intended)"
    return 0
  fi
  local hook_dir
  hook_dir=$(cj_resolve_hook_dir "$target")
  if [ -z "$hook_dir" ]; then
    echo "  GATE-HOOK: cannot resolve $target's git hooks dir — skipping (no-op)"
    return 0
  fi
  mkdir -p "$hook_dir" 2>/dev/null || true
  if gate_hook_body | cj_install_hook "$hook_dir" "pre-commit"; then
    echo "  GATE-HOOK: installed cj-contract-gate pre-commit hook at $hook_dir/pre-commit"
  else
    echo "  GATE-HOOK: could not install the gate hook (a non-workbench pre-commit hook was preserved; see WARN above)"
  fi
  return 0
}

# Standalone: install the contract-gate hook on cwd (or --repo). The explicit
# adoption command — same guarded safety as the auto-install. `--remove`
# uninstalls ONLY a sentinel (workbench-owned) hook; a non-workbench hook is left
# UNTOUCHED. Usage: do_install_contract_gate [--repo <path>] [--remove]
do_install_contract_gate() {
  local target="" remove=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo) target="${2:-}"; shift 2 ;;
      --remove) remove=true; shift ;;
      *) shift ;;
    esac
  done
  [ -n "$target" ] || target="$(pwd)"
  if ! git -C "$target" rev-parse --show-toplevel >/dev/null 2>&1; then
    echo "install-contract-gate: $target is not a git repository — nothing to do (no-op)"
    return 0
  fi
  target=$(git -C "$target" rev-parse --show-toplevel 2>/dev/null)
  if [ "$remove" = true ]; then
    if ! command -v cj_remove_hook >/dev/null 2>&1; then
      echo "install-contract-gate --remove: shared hook lib unavailable — cannot resolve the hook (no-op)"
      return 0
    fi
    local hook_dir outcome
    hook_dir=$(cj_resolve_hook_dir "$target")
    outcome=$(cj_remove_hook "$hook_dir" "pre-commit")
    case "$outcome" in
      removed) echo "install-contract-gate --remove: uninstalled the cj-contract-gate pre-commit hook at $hook_dir/pre-commit" ;;
      foreign) echo "install-contract-gate --remove: $hook_dir/pre-commit is NOT workbench-owned — left untouched" ;;
      absent)  echo "install-contract-gate --remove: no pre-commit hook at $hook_dir — nothing to remove (no-op)" ;;
    esac
    # Symmetric with the hook removal (F000089/S000138): also delete the vendored
    # .cj-contract/ engines + the dropped CI workflow, sentinel-gated (a hand-edited
    # file is left untouched). The workbench self-repo never vendored either, so
    # remove_vendored_gate is a clean no-op there.
    if [ "$(is_workbench_self_repo "$target")" != "yes" ]; then
      remove_vendored_gate "$target"
    fi
    return 0
  fi
  # Seed the portable contracts FIRST (idempotent; present⇒skip; self-repo-skipped
  # + non-git no-op inside do_seed_contracts, corruption-guarded temp→--validate→mv)
  # so ONE command turns a fresh consumer into a LIVE gate — not an inert all-SKIP
  # one — matching docs/adopting-the-contract.md step 1. Without this, a fresh
  # adopter's vendored gate resolves fine but every check REGISTRY=absent-SKIPs
  # (vacuous PASS), so drift is never caught.
  if [ "$(is_workbench_self_repo "$target")" != "yes" ]; then
    echo "install-contract-gate: seeding the portable contracts (idempotent)"
    do_seed_contracts --repo "$target"
  fi
  # Complete adoption (refresh generated surfaces + auto-declare repo docs) so the
  # installed FULLY-HARD gate passes from the next commit — UNLESS this is the
  # workbench self-repo (it authors its own contracts; never mutate them) or a
  # repo that has not adopted any contract (no spec/ registry — nothing to refresh).
  if [ "$(is_workbench_self_repo "$target")" != "yes" ] \
     && { [ -f "$target/spec/doc-spec.md" ] || [ -f "$target/spec/test-spec.md" ] || [ -f "$target/spec/workflow-spec.md" ]; }; then
    echo "install-contract-gate: completing adoption (refresh generated surfaces + auto-declare repo docs)"
    complete_consumer_adoption "$target"
  fi
  echo "install-contract-gate: installing the cj-contract-gate pre-commit hook into $target"
  install_contract_gate_hook "$target"
  # Vendor the 4 gate engines + drop the CI workflow (F000089/S000138) so the
  # consumer's PUSH path enforces the gate on a bare runner — consumer-only,
  # self-repo-skipped inside each helper. Best-effort; never halts.
  if [ "$(is_workbench_self_repo "$target")" != "yes" ]; then
    echo "install-contract-gate: vendoring the gate engines + dropping the CI workflow"
    vendor_gate_engines "$target"
    drop_ci_workflow "$target"
  fi
  return 0
}

# --- install ---

# F000049 / S2 (S000086): bundle install (install == clone). Ensure a managed git
# checkout of the workbench at the bundle path, then delegate to its OWN
# skills-deploy install — that child's REPO_ROOT resolves to the bundle, so the
# flat /CJ_* skill dirs + _cj-shared scripts + templates symlink INTO the bundle
# (gstack's install==clone layout). Env overrides:
#   SKILLS_DEPLOY_BUNDLE_TARGET  bundle path (default ~/.claude/skills/cj-workbench)
#   SKILLS_DEPLOY_BUNDLE_SOURCE  clone source override (tests / offline)
# Clone source falls back to the manifest .source (a local git checkout), then
# upstream_url. Forwarded args ($@) reach the delegated install verbatim.
do_bundle_install() {
  require_jq
  local bundle="${SKILLS_DEPLOY_BUNDLE_TARGET:-$HOME/.claude/skills/cj-workbench}"

  # Manifest-derived defaults (read once): the dev clone (.source) + the GitHub
  # upstream the develop-in-place bundle should TRACK as `origin` (S3/S000087).
  local m msrc murl
  m=$(manifest_read 2>/dev/null || echo '{}')
  msrc=$(echo "$m" | jq -r '.source // empty' 2>/dev/null)
  murl=$(echo "$m" | jq -r '.upstream_url // empty' 2>/dev/null)
  local bundle_upstream="${SKILLS_DEPLOY_BUNDLE_UPSTREAM:-$murl}"

  # Resolve the clone source: explicit override > manifest .source (local git) > upstream_url.
  local src="${SKILLS_DEPLOY_BUNDLE_SOURCE:-}"
  if [ -z "$src" ]; then
    if [ -n "$msrc" ] && [ -d "$msrc/.git" ]; then
      src="$msrc"
    elif [ -n "$murl" ]; then
      src="$murl"
    fi
  fi

  # Ensure the bundle checkout: clone if absent, else best-effort fast-forward.
  if [ -d "$bundle/.git" ]; then
    echo "  BUNDLE: updating existing checkout at $bundle"
    git -C "$bundle" pull --ff-only >/dev/null 2>&1 || echo "  BUNDLE: pull skipped (offline / diverged) — using current checkout"
  else
    if [ -z "$src" ]; then
      echo "ERROR: cannot bootstrap the bundle — no clone source. Set SKILLS_DEPLOY_BUNDLE_SOURCE, or install once normally so the manifest records .source/upstream_url." >&2
      return 1
    fi
    echo "  BUNDLE: cloning $src into $bundle"
    mkdir -p "$(dirname "$bundle")"
    if ! git clone --quiet "$src" "$bundle" 2>/dev/null; then
      echo "ERROR: git clone failed ($src into $bundle)" >&2
      return 1
    fi
  fi

  # Develop-in-place (S3/S000087): point the bundle's `origin` at the GitHub
  # upstream so you can branch/push/PR FROM the bundle — even though it may have
  # been cloned from a LOCAL .source (whose origin would be that local path).
  if [ -n "$bundle_upstream" ]; then
    local cur_origin
    cur_origin=$(git -C "$bundle" remote get-url origin 2>/dev/null || echo "")
    if [ "$cur_origin" != "$bundle_upstream" ]; then
      if git -C "$bundle" remote set-url origin "$bundle_upstream" 2>/dev/null \
         || git -C "$bundle" remote add origin "$bundle_upstream" 2>/dev/null; then
        echo "  BUNDLE: origin → $bundle_upstream (develop-in-place: branch/push/PR from the bundle)"
      fi
    fi
  fi

  # The bundle must be a workbench checkout (carry its own skills-deploy).
  if [ ! -x "$bundle/scripts/skills-deploy" ]; then
    echo "ERROR: $bundle is not a workbench checkout (no scripts/skills-deploy)" >&2
    return 1
  fi

  # Delegate: the bundle's own skills-deploy install resolves REPO_ROOT to the
  # bundle, so the flat /CJ_* dirs symlink INTO the bundle. Env target overrides
  # propagate to the child process.
  echo "  BUNDLE: installing the CJ_ family FROM the bundle checkout"
  if ! bash "$bundle/scripts/skills-deploy" install "$@"; then
    echo "ERROR: bundle-delegated install failed" >&2
    return 1
  fi

  # Stamp the manifest with the install==clone receipt.
  local bcommit
  bcommit=$(git -C "$bundle" rev-parse --short HEAD 2>/dev/null || echo unknown)
  m=$(manifest_read 2>/dev/null || echo '{}')
  echo "$m" | jq --arg bp "$bundle" --arg bc "$bcommit" \
    '. + {install_mode: "bundle", bundle_path: $bp, bundle_commit: $bc}' | manifest_write

  echo ""
  echo "Bundle install complete — install == clone at $bundle (commit $bcommit)"
  echo "  Flat /CJ_* skills now resolve INTO the bundle checkout."
  echo "  Develop in place: cd \"$bundle\" to edit the workbench; 'skills-deploy bundle-status' shows its state."
  echo "  The default 'skills-deploy install' (no --bundle) is ALSO install==clone (F000049/S4) — in place at the"
  echo "  checkout you ran it from; --bundle is the managed-checkout/fresh-consumer bootstrap."
}

# F000049 / S3 (S000087): report the develop-in-place bundle's state (read-only).
# When the install is in bundle mode, the bundle dir IS the dev checkout — this
# surfaces its path, branch, origin, and dirty state so you can develop in place.
do_bundle_status() {
  require_jq
  local m mode bundle
  m=$(manifest_read 2>/dev/null || echo '{}')
  mode=$(echo "$m" | jq -r '.install_mode // "dev-clone"')
  bundle=$(echo "$m" | jq -r '.bundle_path // empty')
  echo "install_mode: $mode"
  # F000049/S4 (S000088): BOTH `in-place` (the default install == clone, declared
  # by do_install) and `bundle` (the managed checkout from --bundle) are install ==
  # clone — `bundle_path` is the dev checkout in both. Only a legacy `dev-clone`
  # install (pre-S4, or no bundle_path recorded) is not install==clone.
  if [ "$mode" = "dev-clone" ] || [ -z "$bundle" ]; then
    echo "  Legacy dev-clone install. Re-run 'skills-deploy install' to declare install==clone-in-place (or '--bundle' for a managed checkout)."
    return 0
  fi
  echo "bundle_path:  $bundle"
  if [ -d "$bundle/.git" ]; then
    local br head origin dirty
    br=$(git -C "$bundle" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
    head=$(git -C "$bundle" rev-parse --short HEAD 2>/dev/null || echo "?")
    origin=$(git -C "$bundle" remote get-url origin 2>/dev/null || echo "(none)")
    if git -C "$bundle" diff --quiet 2>/dev/null && git -C "$bundle" diff --cached --quiet 2>/dev/null; then
      dirty="clean"
    else
      dirty="DIRTY (uncommitted changes)"
    fi
    echo "  branch:     $br ($head)"
    echo "  origin:     $origin"
    echo "  tree:       $dirty"
    echo "  develop-in-place: cd \"$bundle\" to edit the workbench; the flat /CJ_* skills resolve INTO this checkout."
  else
    echo "  WARNING: $bundle is not a git checkout (bundle drift?). Re-run 'skills-deploy install --bundle'."
  fi
}

do_install() {
  require_jq
  local skills=() overwrite=true from_upgrade="" bundle_mode=false
  local args=()
  local prev=""
  for arg in "$@"; do
    if [ "$prev" = "--from-upgrade" ]; then
      from_upgrade="$arg"
      prev=""
      continue
    fi
    case "$arg" in
      --overwrite) overwrite=true ;;
      --no-overwrite) overwrite=false ;;
      --bundle) bundle_mode=true ;;
      --from-upgrade) prev="--from-upgrade" ;;
      *) args+=("$arg") ;;
    esac
  done
  if [ "$prev" = "--from-upgrade" ]; then
    echo "ERROR: --from-upgrade requires a version value" >&2
    exit 2
  fi
  if [ -n "$from_upgrade" ]; then
    if ! printf '%s' "$from_upgrade" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
      echo "ERROR: --from-upgrade value '$from_upgrade' is not a valid 3-digit semver" >&2
      exit 2
    fi
  fi
  set -- "${args[@]+"${args[@]}"}"

  # F000049 / S2 (S000086): --bundle mode (install == clone). Short-circuits the
  # normal dev-clone install: ensure a managed git checkout of the workbench at
  # the bundle path, then delegate to THAT checkout's own skills-deploy so the
  # flat /CJ_* skill dirs symlink INTO the bundle (gstack's install==clone layout).
  # Additive + opt-in — the default `install` (dev-clone symlinks) is untouched.
  if [ "$bundle_mode" = true ]; then
    local _fwd=()
    [ "$overwrite" = false ] && _fwd+=(--no-overwrite)
    do_bundle_install "${_fwd[@]+"${_fwd[@]}"}" "$@"
    return $?
  fi

  if [ $# -gt 0 ]; then
    skills=("$@")
    # Resolve dependencies
    local resolved=()
    for s in "${skills[@]}"; do
      for dep in $(skill_deps "$s"); do
        # Add dep if not already in list
        local found=0
        for r in "${resolved[@]+"${resolved[@]}"}"; do [ "$r" = "$dep" ] && found=1; done
        [ "$found" -eq 0 ] && resolved+=("$dep")
      done
      resolved+=("$s")
    done
    skills=("${resolved[@]}")
  else
    while IFS= read -r s; do skills+=("$s"); done < <(discover_skills)
  fi

  local manifest installed=0 skipped=0 migrated=0
  manifest=$(manifest_read)

  # Resolve install mode ONCE per run (S000079). symlink-capable platforms
  # (macOS/Linux/WSL2) take the byte-identical legacy `ln -snf` path; Git Bash
  # (no usable symlinks) falls back to copy-mode (`cp` + recorded source_checksums).
  local install_kind
  if [ "$(_can_symlink)" = "yes" ]; then
    install_kind="symlink"
  else
    install_kind="copy"
    echo "  INFO: symlinks unavailable in $SKILLS_TARGET — installing skills in copy-mode"
  fi

  for name in "${skills[@]}"; do
    # Source directory is catalog-driven (F000006): dirname(files[0]). Empty
    # for templates-only entries (handled below).
    local src
    src=$(skill_source_dir "$name")
    # Templates-only catalog entries have no skill directory (empty files array)
    local files_count
    files_count=$(jq -r --arg n "$name" '.[] | select(.name == $n) | .files | length' "$CATALOG" 2>/dev/null || echo "0")
    # -n guard: a catalog-absent name yields empty (jq match miss, exit 0) — avoid
    # the "integer expression expected" crash (same class as do_remove's fc_rm).
    if [ -n "$files_count" ] && [ "$files_count" -eq 0 ]; then
      echo "  OK: $name is templates-only (no skill directory)"
      manifest=$(echo "$manifest" | jq --arg n "$name" --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        '.skills[$n] = {templates_only: true, installed_at: $t}')
      installed=$((installed + 1))
      continue
    fi
    if [ ! -d "$src" ]; then
      echo "  SKIP: $name not found in repo" >&2
      skipped=$((skipped + 1))
      continue
    fi

    local owner
    owner=$(skill_owner "$name")

    case "$owner" in
      gstack)
        echo "  SKIP: $name is owned by gstack"
        skipped=$((skipped + 1))
        continue
        ;;
      other)
        echo "  SKIP: $name is owned by another tool"
        skipped=$((skipped + 1))
        continue
        ;;
      manual)
        # Migration: check if files match repo
        local dominated=true
        for f in "$SKILLS_TARGET/$name"/*.md; do
          [ -f "$f" ] || continue
          local fname
          fname=$(basename "$f")
          if [ -f "$src/$fname" ]; then
            if ! diff -q "$f" "$src/$fname" >/dev/null 2>&1; then
              echo "  WARN: $name/$fname has local modifications, skipping migration"
              dominated=false
              break
            fi
          fi
        done
        if [ "$dominated" = false ]; then
          skipped=$((skipped + 1))
          continue
        fi
        echo "  MIGRATE: $name (flat copy -> symlinks)"
        migrated=$((migrated + 1))
        # Remove old files, recreate as symlinks below
        rm -f "$SKILLS_TARGET/$name"/*.md 2>/dev/null || true
        ;;
      ours)
        # Update existing symlinks
        ;;
      none)
        mkdir -p "$SKILLS_TARGET/$name"
        ;;
    esac

    # Install all .md and .json files from source. symlink-mode: byte-identical
    # legacy `ln -snf`. copy-mode (S000079): `cp` the file + accumulate its SHA256
    # into a per-skill source_checksums object (keyed by filename) so copy-mode
    # doctor/relink have a source of truth to verify against.
    local checksums_json="{}"
    for f in "$src"/*.md "$src"/*.json; do
      [ -f "$f" ] || continue
      local fname
      fname=$(basename "$f")
      # Skip dev-only files
      case "$fname" in CHANGELOG.md|DESIGN.md) continue ;; esac
      if [ "$install_kind" = "symlink" ]; then
        ln -snf "$f" "$SKILLS_TARGET/$name/$fname"
      else
        # Replace any pre-existing symlink/file with a regular-file copy.
        rm -f "$SKILLS_TARGET/$name/$fname" 2>/dev/null || true
        cp "$f" "$SKILLS_TARGET/$name/$fname"
        local fsum
        fsum=$(file_checksum "$f"); [ -n "$fsum" ] || fsum="unknown"
        checksums_json=$(echo "$checksums_json" | jq --arg k "$fname" --arg v "$fsum" '.[$k] = $v')
      fi
    done

    # Install subdirectories from source (examples/, reference/, philosophy/, fixtures/).
    # symlink-mode: legacy `ln -snf`. copy-mode (S000079): rm -rf + cp -R (recursive
    # copy). Subdir contents are presence-checked by doctor, not deep-hashed.
    for d in "$src"/*/; do
      [ -d "$d" ] || continue
      local dname
      dname=$(basename "$d")
      local dtarget="$SKILLS_TARGET/$name/$dname"
      # Migration guard: if target is a real dir (not symlink), diff before replacing
      if [ -d "$dtarget" ] && [ ! -L "$dtarget" ]; then
        local ddom=true
        for df in "$dtarget"/*; do
          [ -f "$df" ] || continue
          local dfname
          dfname=$(basename "$df")
          if [ -f "$d/$dfname" ]; then
            if ! diff -q "$df" "$d/$dfname" >/dev/null 2>&1; then
              echo "  WARN: $name/$dname/$dfname has local modifications, skipping subdir migration"
              ddom=false
              break
            fi
          fi
        done
        if [ "$ddom" = true ]; then
          rm -rf "$dtarget"
        else
          continue
        fi
      fi
      if [ "$install_kind" = "symlink" ]; then
        ln -snf "$d" "$dtarget"
      else
        rm -rf "$dtarget" 2>/dev/null || true
        cp -R "$d" "$dtarget"
      fi
    done

    # Manifest path comes from catalog files[0] so it reflects the real source
    # location, not a guess. symlink-mode records {path, installed_at, install_kind};
    # copy-mode additionally records source_checksums for drift detection (S000079).
    local manifest_path
    manifest_path=$(skill_md_path "$name")
    if [ "$install_kind" = "symlink" ]; then
      manifest=$(echo "$manifest" | jq --arg n "$name" --arg p "$manifest_path" --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        '.skills[$n] = {path: $p, installed_at: $t, install_kind: "symlink"}')
    else
      manifest=$(echo "$manifest" | jq --arg n "$name" --arg p "$manifest_path" --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" --argjson sc "$checksums_json" \
        '.skills[$n] = {path: $p, installed_at: $t, install_kind: "copy", source_checksums: $sc}')
    fi
    installed=$((installed + 1))
  done

  # Deploy templates for installed skills
  local tpl_installed=0 tpl_skipped=0
  mkdir -p "$TEMPLATES_TARGET"

  for name in "${skills[@]}"; do
    # Source dir is catalog-driven (F000006); empty for templates-only entries.
    local src
    src=$(skill_source_dir "$name")
    # Templates-only entries have no skill directory but still deploy templates
    local fc
    fc=$(jq -r --arg n "$name" '.[] | select(.name == $n) | .files | length' "$CATALOG" 2>/dev/null || echo "0")
    # -n guard: a catalog-absent name yields empty (jq match miss, exit 0) — avoid
    # the "integer expression expected" crash (same class as do_remove's fc_rm).
    if [ -n "$fc" ] && [ "$fc" -ne 0 ]; then
      [ -d "$src" ] || continue
      # Skip skills we didn't actually install (gstack/other owned)
      local owner
      owner=$(skill_owner "$name")
      case "$owner" in gstack|other) continue ;; esac
    fi

    # Templates source base (F000006): default "templates" preserves existing
    # behavior; override via catalog templates_source field for skills whose
    # template source lives elsewhere.
    local tpl_base
    tpl_base=$(skill_templates_source "$name")

    for tpl in $(skill_templates "$name"); do
      validate_template_name "$tpl" || { tpl_skipped=$((tpl_skipped + 1)); continue; }

      # When templates_source is the default, entry is path under templates/.
      # When overridden, entry's basename is joined with the override base —
      # the {skill}/ prefix in the entry is the DST organizing subfolder, not
      # part of the SRC path under the override.
      local tpl_src
      if [ "$tpl_base" = "templates" ]; then
        tpl_src="$TEMPLATES_SRC/$tpl"
      else
        tpl_src="$REPO_ROOT/$tpl_base/$(basename "$tpl")"
      fi
      local tpl_dst="$TEMPLATES_TARGET/$tpl"
      mkdir -p "$(dirname "$tpl_dst")"

      # Check for shadowing by higher-priority path
      if [ -f "$HOME/.claude/spec/templates/$tpl" ]; then
        echo "  WARN: $tpl — shadowed by ~/.claude/spec/templates/$tpl (takes priority; remove it to use deployed version)"
      fi

      if [ ! -f "$tpl_src" ]; then
        echo "  WARN: $tpl — source not found at $tpl_src, skipping"
        tpl_skipped=$((tpl_skipped + 1))
        continue
      fi

      local src_sum
      src_sum=$(file_checksum "$tpl_src")
      if [ "$src_sum" = "" ]; then src_sum="unknown"; fi

      if [ -f "$tpl_dst" ]; then
        local dst_sum
        dst_sum=$(file_checksum "$tpl_dst")
        if [ "$src_sum" = "$dst_sum" ]; then
          # Same content — just update ownership
          manifest=$(echo "$manifest" | jq --arg t "$tpl" --arg s "$name" --arg sum "$src_sum" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            '.templates[$t] = (.templates[$t] // {owners: [], source_checksum: $sum, installed_at: $ts}) | .templates[$t].owners = ([.templates[$t].owners // [] | .[] | select(. != $s)] + [$s]) | .templates[$t].source_checksum = $sum')
        elif [ "$overwrite" = true ]; then
          cp "$tpl_src" "$tpl_dst" || { echo "  WARN: failed to copy $tpl"; tpl_skipped=$((tpl_skipped + 1)); continue; }
          echo "  UPDATE: $tpl (checksum differs)"
          manifest=$(echo "$manifest" | jq --arg t "$tpl" --arg s "$name" --arg sum "$src_sum" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            '.templates[$t] = (.templates[$t] // {owners: [], source_checksum: $sum, installed_at: $ts}) | .templates[$t].owners = ([.templates[$t].owners // [] | .[] | select(. != $s)] + [$s]) | .templates[$t].source_checksum = $sum')
          tpl_installed=$((tpl_installed + 1))
        else
          echo "  PRESERVE: $tpl — exists with different content (--no-overwrite, keeping deployed copy)"
          # Still update ownership even if we skip the copy
          manifest=$(echo "$manifest" | jq --arg t "$tpl" --arg s "$name" --arg sum "$dst_sum" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            '.templates[$t] = (.templates[$t] // {owners: [], source_checksum: $sum, installed_at: $ts}) | .templates[$t].owners = ([.templates[$t].owners // [] | .[] | select(. != $s)] + [$s])')
          tpl_skipped=$((tpl_skipped + 1))
        fi
      else
        cp "$tpl_src" "$tpl_dst" || { echo "  WARN: failed to copy $tpl"; tpl_skipped=$((tpl_skipped + 1)); continue; }
        manifest=$(echo "$manifest" | jq --arg t "$tpl" --arg s "$name" --arg sum "$src_sum" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
          '.templates[$t] = (.templates[$t] // {owners: [], source_checksum: $sum, installed_at: $ts}) | .templates[$t].owners = ([.templates[$t].owners // [] | .[] | select(. != $s)] + [$s]) | .templates[$t].source_checksum = $sum')
        tpl_installed=$((tpl_installed + 1))
      fi
    done
  done

  # Deploy rules files (global Claude Code rules from rules/ directory)
  local rules_installed=0
  if [ -d "$RULES_SRC" ]; then
    mkdir -p "$RULES_TARGET"
    for rule_file in "$RULES_SRC"/*.md; do
      [ -f "$rule_file" ] || continue
      local rule_name
      rule_name=$(basename "$rule_file")
      # Skip documentation files not intended as global Claude Code instructions.
      case "$rule_name" in README.md|NOTES.md|DEVELOPMENT.md|CHANGELOG.md) continue ;; esac
      local rule_dst="$RULES_TARGET/$rule_name"
      if [ -f "$rule_dst" ]; then
        local rule_src_sum rule_dst_sum
        rule_src_sum=$(file_checksum "$rule_file")
        rule_dst_sum=$(file_checksum "$rule_dst")
        if [ "$rule_src_sum" = "$rule_dst_sum" ]; then
          continue
        elif [ "$overwrite" = true ]; then
          cp "$rule_file" "$rule_dst" || { echo "  WARN: failed to copy $rule_name (skipping)"; continue; }
          echo "  RULE: updated $rule_name"
          rules_installed=$((rules_installed + 1))
        else
          echo "  WARN: $rule_name — rule exists with different content (--no-overwrite, keeping deployed copy; routing drift possible)"
        fi
      else
        cp "$rule_file" "$rule_dst" || { echo "  WARN: failed to copy $rule_name (skipping)"; continue; }
        echo "  RULE: installed $rule_name"
        rules_installed=$((rules_installed + 1))
      fi
    done
  fi

  # Deploy shared scripts to _cj-shared/scripts/ (F000049 / S000085).
  # The shared scripts/*.sh helpers (+ skills-update-check) travel with the
  # install so the orchestrator-family skills (CJ_goal_feature / CJ_goal_defect /
  # CJ_goal_todo_fix / CJ_document-release) resolve them from this deployed home
  # (bundle-first, .source legacy fallback) instead of a separate source clone.
  # Copy-mode + SHA256 drift tracking, like templates. Deposited as a SET so the
  # scripts' dirname-relative sibling resolution (BASH_SOURCE) keeps every
  # transitive helper co-located in one dir.
  local shared_installed=0 shared_skipped=0 shared_pruned=0
  if [ -d "$SHARED_SCRIPTS_SRC" ]; then
    mkdir -p "$SHARED_SCRIPTS_TARGET"
    for sh_src in "$SHARED_SCRIPTS_SRC"/*.sh "$SHARED_SCRIPTS_SRC/skills-update-check"; do
      [ -f "$sh_src" ] || continue
      local sh_base sh_dst sh_src_sum
      sh_base=$(basename "$sh_src")
      sh_dst="$SHARED_SCRIPTS_TARGET/$sh_base"
      sh_src_sum=$(file_checksum "$sh_src")
      [ -n "$sh_src_sum" ] || sh_src_sum="unknown"
      if [ -f "$sh_dst" ]; then
        local sh_dst_sum
        sh_dst_sum=$(file_checksum "$sh_dst")
        if [ "$sh_src_sum" = "$sh_dst_sum" ]; then
          :  # same content — fall through to refresh the manifest record
        elif [ "$overwrite" = true ]; then
          cp "$sh_src" "$sh_dst" || { echo "  WARN: failed to copy shared script $sh_base (skipping)"; shared_skipped=$((shared_skipped + 1)); continue; }
          chmod +x "$sh_dst" 2>/dev/null || true
          echo "  SHARED: updated $sh_base (checksum differs)"
          shared_installed=$((shared_installed + 1))
        else
          echo "  WARN: $sh_base — shared script exists with different content (--no-overwrite, keeping deployed copy)"
          sh_src_sum="$sh_dst_sum"
          shared_skipped=$((shared_skipped + 1))
        fi
      else
        cp "$sh_src" "$sh_dst" || { echo "  WARN: failed to copy shared script $sh_base (skipping)"; shared_skipped=$((shared_skipped + 1)); continue; }
        chmod +x "$sh_dst" 2>/dev/null || true
        shared_installed=$((shared_installed + 1))
      fi
      manifest=$(echo "$manifest" | jq --arg k "$sh_base" --arg sum "$sh_src_sum" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        '.shared_scripts[$k] = {source_checksum: $sum, installed_at: $ts}')
    done

    # Prune orphaned shared scripts (T000051). A prior install deposits each
    # shared script + manifest-tracks it in `.shared_scripts`, but a script
    # later DELETED from source was never removed from the deployed home or the
    # manifest — leaving stale orphans (e.g. test-pipeline.sh, gate-spec.sh).
    # Key the prune off the MANIFEST keys, NOT a raw scandir of the target, so
    # only scripts a prior install deployed+tracked are eligible — a hand-placed
    # file the install never recorded is never touched (ownership safety). This
    # block is INSIDE the `-d "$SHARED_SCRIPTS_SRC"` guard so an unreadable
    # source dir never triggers a wipe of the deployed set.
    # `|| true`: the loop's final `[ -f ]` can exit non-zero (e.g. when
    # skills-update-check is absent in a fixture), and under `set -e` that
    # non-zero from the command substitution would abort the whole install at
    # the assignment. An empty source set is the correct non-fatal outcome.
    local shared_source_set
    shared_source_set=$(
      for sh_src in "$SHARED_SCRIPTS_SRC"/*.sh "$SHARED_SCRIPTS_SRC/skills-update-check"; do
        [ -f "$sh_src" ] && basename "$sh_src"
      done
    ) || true
    local pruned_key
    while IFS= read -r pruned_key; do
      [ -n "$pruned_key" ] || continue
      if ! printf '%s\n' "$shared_source_set" | grep -qxF "$pruned_key"; then
        rm -f "$SHARED_SCRIPTS_TARGET/$pruned_key"
        manifest=$(echo "$manifest" | jq --arg k "$pruned_key" 'del(.shared_scripts[$k])')
        echo "  SHARED: pruned $pruned_key (no source counterpart)"
        shared_pruned=$((shared_pruned + 1))
      fi
    done < <(echo "$manifest" | jq -r '.shared_scripts // {} | keys[]')
  fi

  # Resolve the manifest `source` to the MAIN repo toplevel (T000025).
  # `$REPO_ROOT` (line 7) is `dirname(script)/..`, which under `.claude/worktrees/<name>/`
  # points at the ephemeral worktree. Once the worktree is removed, `skills-deploy doctor`
  # reports `FAIL: source path '<dead-worktree>' no longer exists`, and update-check's
  # `git pull --ff-only` fallback silently breaks. `git rev-parse --path-format=absolute
  # --git-common-dir` resolves the main repo's `.git` dir regardless of which worktree
  # the script ran from; its parent is the main toplevel. Fallback to `$REPO_ROOT` if
  # the git call fails (e.g. when the repo is unusual or in a non-worktree context).
  local main_toplevel
  main_toplevel=$(dirname "$(git -C "$REPO_ROOT" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" 2>/dev/null) || true
  if [ -z "$main_toplevel" ] || [ ! -d "$main_toplevel" ]; then
    main_toplevel="$REPO_ROOT"
  fi

  # Read collection version from the SAME repo the manifest `source` points at.
  # Must be `$main_toplevel`, not `$REPO_ROOT`: `doctor` later reads
  # `current_cv` from `$source/VERSION` (= `$main_toplevel/VERSION`). Sourcing
  # `col_ver` from `$REPO_ROOT/VERSION` (the ephemeral worktree, routinely ahead
  # of the stale main checkout during worktree-based dev) split the two endpoints
  # of doctor's drift check across two different VERSION files, emitting a
  # spurious "installed != current" WARN on every healthy worktree install
  # (T000025 moved `source` but left this read on `$REPO_ROOT`). The exact
  # deployed HEAD is still captured separately in the manifest `commit` field.
  local col_ver="unknown"
  if [ -f "$main_toplevel/VERSION" ]; then
    col_ver=$(tr -d '[:space:]' < "$main_toplevel/VERSION")
  fi

  # Capture origin URL at install time (T000031). Stored in manifest so
  # skills-update-check can verify it hasn't been redirected before recommending
  # `git pull --ff-only origin main` against `$source`. Empty when the source
  # repo has no `origin` remote (rare; skill installs from non-git source dir).
  local upstream_url
  upstream_url=$(git -C "$main_toplevel" remote get-url origin 2>/dev/null || true)

  # Write manifest.
  # F000049 / S4 (S000088): the default install declares install == clone IN PLACE.
  # `source` already equals `main_toplevel` (the checkout this install ran from), so
  # the install IS the clone — stamp `install_mode: "in-place"` + `bundle_path: $s`
  # to make that a first-class receipt (D1-B; no relocation). The `--bundle` path
  # (do_bundle_install) runs THIS delegated install first, then OVERWRITES with
  # `install_mode: "bundle"` — so a --bundle install still ends as `bundle`, while a
  # plain `install` ends as `in-place`. Either way `bundle_path` = the dev checkout.
  echo "$manifest" | jq --arg s "$main_toplevel" --arg r "jcl2018/claude-skills-templates" \
    --arg c "$(git -C "$REPO_ROOT" rev-parse --short HEAD 2>/dev/null || echo unknown)" \
    --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --arg cv "$col_ver" \
    --arg u "$upstream_url" \
    '. + {source: $s, repo: $r, commit: $c, installed_at: $t, collection_version: $cv, upstream_url: $u, install_mode: "in-place", bundle_path: $s}' | manifest_write

  # Write JUST_UPGRADED marker if invoked from the update-check upgrade flow.
  # Format: single line "<from_version> <to_version>" — consumed once by
  # skills-update-check (read, unlink, emit) on the next skill invocation.
  if [ -n "$from_upgrade" ]; then
    local marker_path="${SKILLS_TEMPLATES_MARKER:-$HOME/.claude/.skills-templates-just-upgraded}"
    printf '%s %s\n' "$from_upgrade" "$col_ver" > "$marker_path" 2>/dev/null || true
  fi

  echo ""
  echo "Skills — Installed: $installed  Migrated: $migrated  Skipped: $skipped"
  echo "Templates — Installed: $tpl_installed  Skipped: $tpl_skipped"
  if [ "$rules_installed" -gt 0 ]; then
    echo "Rules — Installed: $rules_installed"
  fi
  if [ "$shared_installed" -gt 0 ] || [ "$shared_skipped" -gt 0 ] || [ "$shared_pruned" -gt 0 ]; then
    echo "Shared scripts — Installed: $shared_installed  Skipped: $shared_skipped  Pruned: $shared_pruned"
  fi

  # Consumer-path contract seeding (F000069 / S000116). AFTER the skills install,
  # force-seed the three contracts into the CWD when it is a consumer git repo —
  # idempotent + forced, no flag. The workbench self-install (install==clone:
  # source == bundle_path == cwd) is the self-repo and is SKIPPED by
  # do_seed_contracts' airtight data-loss guard; a non-git cwd is a clean no-op
  # (git-repo guard). A single visible note reports whether seeding ran; the
  # per-contract detail lines come from do_seed_contracts itself.
  local _seed_cwd
  _seed_cwd="$(pwd)"
  if git -C "$_seed_cwd" rev-parse --show-toplevel >/dev/null 2>&1; then
    if [ "$(is_workbench_self_repo "$_seed_cwd")" = "yes" ]; then
      echo "Contracts — skipped (workbench self-repo; authored contracts left untouched)"
    else
      echo "Contracts — seeding consumer repo contracts (doc-spec / test-spec / workflow-spec):"
      do_seed_contracts --repo "$_seed_cwd"
      # Complete adoption (F000069 / S000117): make the freshly-seeded consumer
      # CONTRACT-CLEAN so the FULLY-HARD gate passes from the first commit — refresh
      # the generated surfaces + auto-declare the seeded/generated docs. AFTER the
      # seeding (the contracts must exist) + BEFORE the gate-hook install (so the
      # auto-installed gate does not block the next commit). Idempotent + best-effort.
      echo "Contracts — completing adoption (refresh generated surfaces + auto-declare repo docs):"
      complete_consumer_adoption "$_seed_cwd"
      # Contract-gate pre-commit hook auto-install (F000069 / S000117). AFTER the
      # seeding + adoption (the repo must be contract-clean before enforcing it) +
      # in the SAME consumer-path block. Guarded: workbench-self / custom-hookspath /
      # non-git all SKIP cleanly; a non-workbench pre-commit hook is backed up, not
      # clobbered. Best-effort — never halts the install.
      echo "Contract gate — installing the consumer pre-commit enforcement hook:"
      install_contract_gate_hook "$_seed_cwd"
      # Vendor the 4 gate engines into .cj-contract/ + drop the CI workflow
      # (F000089/S000138) so the consumer's PUSH path also enforces the gate on a
      # bare CI runner with no ~/.claude. Consumer-only (this block already excludes
      # the workbench self-repo); each helper is self-repo-skipped + best-effort.
      echo "Contract gate — vendoring the gate engines + dropping the CI workflow:"
      vendor_gate_engines "$_seed_cwd"
      drop_ci_workflow "$_seed_cwd"
    fi
  else
    echo "Contracts — skipped (install run from a non-git directory)"
  fi
}

# --- remove ---

do_remove() {
  require_jq
  local force=false remove_all=false
  local skills=()

  for arg in "$@"; do
    case "$arg" in
      --all) remove_all=true; while IFS= read -r s; do skills+=("$s"); done < <(manifest_read | jq -r '.skills // {} | keys[]'); continue ;;
      --force) force=true; continue ;;
      *) skills+=("$arg") ;;
    esac
  done

  if [ ${#skills[@]} -eq 0 ]; then
    echo "ERROR: specify skill names or --all" >&2
    echo "Usage: skills-deploy remove <skill...> [--force]" >&2
    echo "       skills-deploy remove --all [--force]" >&2
    exit 1
  fi

  local manifest removed=0 template_errors=0
  manifest=$(manifest_read)

  for name in "${skills[@]}"; do
    # Check reverse dependencies
    if [ "$force" = false ]; then
      for rdep in $(reverse_deps "$name"); do
        if echo "$manifest" | jq -e --arg n "$rdep" '.skills[$n]' >/dev/null 2>&1; then
          echo "  WARN: $name is required by $rdep (installed). Use --force to remove anyway."
          continue 2
        fi
      done
    fi

    # Check if this is a templates-only entry
    local tpl_only=false
    local fc_rm
    fc_rm=$(jq -r --arg n "$name" '.[] | select(.name == $n) | .files | length' "$CATALOG" 2>/dev/null || echo "0")
    # A catalog-absent skill (deprecated/renamed but still deployed) makes the jq
    # `select` match nothing → empty output + jq exit 0, which defeats the
    # `|| echo "0"` fallback (it only catches jq *failure*). The -n guard stops
    # `[ "" -eq 0 ]` from erroring "integer expression expected". Empty (absent)
    # MUST stay tpl_only=false so the dir-removal block below still runs — do NOT
    # default empty→0 (that sets tpl_only=true, skips removal, orphans the dir).
    [ -n "$fc_rm" ] && [ "$fc_rm" -eq 0 ] && tpl_only=true

    # Read the recorded install_kind for this skill (S000079). Absent field →
    # "symlink" (back-compat: installs predating the field were all symlinks).
    local rm_kind
    rm_kind=$(echo "$manifest" | jq -r --arg n "$name" '.skills[$n].install_kind // "symlink"')

    if [ "$tpl_only" = false ]; then
      if [ "$rm_kind" = "copy" ]; then
        # Copy-mode: the installed files are regular-file copies we own. Remove the
        # recorded regular files + any copied subdirs. skill_owner() returns "manual"
        # for regular files, so the symlink-mode ownership gate is skipped here; the
        # manifest install_kind=copy record is the ownership signal.
        for f in "$SKILLS_TARGET/$name"/*.md "$SKILLS_TARGET/$name"/*.json; do
          [ -f "$f" ] && [ ! -L "$f" ] && rm -f "$f"
        done
        for d in "$SKILLS_TARGET/$name"/*/; do
          local dpath
          dpath="$(dirname "$d")/$(basename "$d")"
          [ -d "$dpath" ] && [ ! -L "$dpath" ] && rm -rf "$dpath"
        done
        rmdir "$SKILLS_TARGET/$name" 2>/dev/null || true
      else
        # Verify ownership before removing
        local owner
        owner=$(skill_owner "$name")
        if [ "$owner" != "ours" ]; then
          echo "  SKIP: $name is not owned by this repo (owner: $owner)"
          continue
        fi

        # Remove symlinks only (not regular files)
        for f in "$SKILLS_TARGET/$name"/*.md "$SKILLS_TARGET/$name"/*.json; do
          [ -L "$f" ] && rm -f "$f"
        done
        # Remove subdirectory symlinks
        for d in "$SKILLS_TARGET/$name"/*/; do
          local dpath
          dpath="$(dirname "$d")/$(basename "$d")"
          [ -L "$dpath" ] && rm -f "$dpath"
        done
        rmdir "$SKILLS_TARGET/$name" 2>/dev/null || true
      fi
    fi

    # Clean up templates owned by this skill
    for tpl in $(skill_templates "$name"); do
      validate_template_name "$tpl" || continue
      # Remove this skill from owners
      manifest=$(echo "$manifest" | jq --arg t "$tpl" --arg s "$name" \
        'if .templates[$t] then .templates[$t].owners = [.templates[$t].owners // [] | .[] | select(. != $s)] else . end')
      # If no owners left, delete template file and manifest entry
      local owner_count
      owner_count=$(echo "$manifest" | jq --arg t "$tpl" '.templates[$t].owners // [] | length')
      if [ "$owner_count" -eq 0 ]; then
        if [ -f "$TEMPLATES_TARGET/$tpl" ]; then
          if rm -f "$TEMPLATES_TARGET/$tpl"; then
            echo "  TEMPLATE: removed $tpl"
          else
            echo "  WARN: failed to remove $tpl"
            template_errors=$((template_errors + 1))
          fi
        fi
        manifest=$(echo "$manifest" | jq --arg t "$tpl" 'del(.templates[$t])')
      fi
    done

    manifest=$(echo "$manifest" | jq --arg n "$name" 'del(.skills[$n])')
    removed=$((removed + 1))
  done

  # Clean up deployed rules only when removing all skills (rules are global, not per-skill).
  if [ "$remove_all" = true ] && [ -d "$RULES_SRC" ]; then
    for rule_file in "$RULES_SRC"/*.md; do
      [ -f "$rule_file" ] || continue
      local rule_name
      rule_name=$(basename "$rule_file")
      case "$rule_name" in README.md|NOTES.md|DEVELOPMENT.md|CHANGELOG.md) continue ;; esac
      if [ -f "$RULES_TARGET/$rule_name" ]; then
        if rm -f "$RULES_TARGET/$rule_name"; then
          echo "  RULE: removed $rule_name"
        fi
      fi
    done
  fi

  # Prune orphaned template owners (owners referencing skills no longer installed)
  local installed_skills
  installed_skills=$(echo "$manifest" | jq -r '[.skills // {} | keys[]] | join(",")')
  for tpl in $(echo "$manifest" | jq -r '.templates // {} | keys[]'); do
    manifest=$(echo "$manifest" | jq --arg t "$tpl" --arg installed "$installed_skills" \
      '.templates[$t].owners = [.templates[$t].owners // [] | .[] | select(. as $o | ($installed | split(",")) | index($o))]')
    local owner_count
    owner_count=$(echo "$manifest" | jq --arg t "$tpl" '.templates[$t].owners // [] | length')
    if [ "$owner_count" -eq 0 ]; then
      [ -f "$TEMPLATES_TARGET/$tpl" ] && rm -f "$TEMPLATES_TARGET/$tpl"
      manifest=$(echo "$manifest" | jq --arg t "$tpl" 'del(.templates[$t])')
    fi
  done

  # Write manifest or remove if empty
  local remaining tpl_remaining
  remaining=$(echo "$manifest" | jq '.skills // {} | length')
  tpl_remaining=$(echo "$manifest" | jq '.templates // {} | length')
  if [ "$remaining" -eq 0 ] && [ "$tpl_remaining" -eq 0 ] && [ "$template_errors" -eq 0 ]; then
    rm -f "$MANIFEST"
    echo "Removed: $removed (manifest cleaned up)"
  else
    echo "$manifest" | manifest_write
    echo "Removed: $removed"
  fi
}

# --- relink ---

do_relink() {
  require_jq
  local manifest fixed=0 ok=0
  manifest=$(manifest_read)

  if [ "$(echo "$manifest" | jq '.skills // {} | length')" -eq 0 ]; then
    echo "No skills in manifest. Run 'skills-deploy install' first."
    return
  fi

  local source
  source=$(echo "$manifest" | jq -r '.source // ""')

  for name in $(echo "$manifest" | jq -r '.skills // {} | keys[]'); do
    # Source dir is catalog-driven (F000006): read manifest .skills[$n].path,
    # then dirname it. Falls back to the legacy skills/{name}/ shape when the
    # manifest has no path field (older installs from before F000006).
    local manifest_path
    manifest_path=$(echo "$manifest" | jq -r --arg n "$name" '.skills[$n].path // ""')
    local src
    if [ -n "$manifest_path" ]; then
      src="$source/$(dirname "$manifest_path")"
    else
      src="$source/skills/$name"
    fi
    if [ ! -d "$src" ]; then
      echo "  WARN: $name source missing at $src"
      continue
    fi

    # Branch on recorded install_kind (S000079); absent field → "symlink"
    # (back-compat for installs predating the field).
    local rl_kind
    rl_kind=$(echo "$manifest" | jq -r --arg n "$name" '.skills[$n].install_kind // "symlink"')

    mkdir -p "$SKILLS_TARGET/$name"
    for f in "$src"/*.md "$src"/*.json; do
      [ -f "$f" ] || continue
      local fname
      fname=$(basename "$f")
      case "$fname" in CHANGELOG.md|DESIGN.md) continue ;; esac
      local target="$SKILLS_TARGET/$name/$fname"
      if [ "$rl_kind" = "copy" ]; then
        # Re-copy when the installed file is missing or its SHA drifted from the
        # recorded source_checksums entry (mirrors template relink-on-drift below).
        local expected_sum actual_sum
        expected_sum=$(echo "$manifest" | jq -r --arg n "$name" --arg k "$fname" '.skills[$n].source_checksums[$k] // ""')
        if [ -f "$target" ] && [ ! -L "$target" ]; then
          actual_sum=$(file_checksum "$target")
        else
          actual_sum=""
        fi
        if [ -n "$actual_sum" ] && [ "$actual_sum" = "$expected_sum" ]; then
          ok=$((ok + 1))
        else
          rm -f "$target" 2>/dev/null || true
          cp "$f" "$target"
          fixed=$((fixed + 1))
        fi
      else
        if [ -L "$target" ] && [ "$(readlink "$target")" = "$f" ]; then
          ok=$((ok + 1))
        else
          ln -snf "$f" "$target"
          fixed=$((fixed + 1))
        fi
      fi
    done

    # Repair subdirectories. copy-mode: presence-check + re-copy if missing.
    # symlink-mode: legacy symlink repair.
    for d in "$src"/*/; do
      [ -d "$d" ] || continue
      local dname
      dname=$(basename "$d")
      local dtarget="$SKILLS_TARGET/$name/$dname"
      if [ "$rl_kind" = "copy" ]; then
        if [ -d "$dtarget" ] && [ ! -L "$dtarget" ]; then
          ok=$((ok + 1))
        else
          rm -rf "$dtarget" 2>/dev/null || true
          cp -R "$d" "$dtarget"
          fixed=$((fixed + 1))
        fi
      else
        if [ -L "$dtarget" ] && [ -e "$dtarget" ]; then
          ok=$((ok + 1))
        else
          ln -snf "$d" "$dtarget"
          fixed=$((fixed + 1))
        fi
      fi
    done
  done

  # Repair templates
  local tpl_fixed=0 tpl_ok=0
  for tpl in $(echo "$manifest" | jq -r '.templates // {} | keys[]'); do
    local tpl_file="$TEMPLATES_TARGET/$tpl"
    local tpl_src="$TEMPLATES_SRC/$tpl"

    if [ ! -f "$tpl_file" ]; then
      # Missing — re-copy if source exists
      if [ -f "$tpl_src" ]; then
        mkdir -p "$(dirname "$tpl_file")"
        cp "$tpl_src" "$tpl_file" && tpl_fixed=$((tpl_fixed + 1)) || echo "  WARN: failed to restore $tpl"
        # Update checksum in manifest
        local new_sum
        new_sum=$(file_checksum "$tpl_src")
        manifest=$(echo "$manifest" | jq --arg t "$tpl" --arg sum "$new_sum" '.templates[$t].source_checksum = $sum')
      else
        echo "  WARN: $tpl — source not found at $tpl_src, cannot restore"
      fi
    else
      local expected actual
      expected=$(echo "$manifest" | jq -r --arg t "$tpl" '.templates[$t].source_checksum // ""')
      actual=$(file_checksum "$tpl_file")
      if [ -n "$expected" ] && [ "$expected" != "$actual" ] && [ "$expected" != "unknown" ]; then
        echo "  WARN: $tpl has local changes. Run 'skills-deploy install' to reset (or pass --no-overwrite to keep them)."
      else
        tpl_ok=$((tpl_ok + 1))
      fi
    fi
  done

  # Write updated manifest if templates were repaired
  if [ "$tpl_fixed" -gt 0 ]; then
    echo "$manifest" | manifest_write
  fi

  echo "Skills — Relinked: $fixed fixed, $ok already correct"
  echo "Templates — Restored: $tpl_fixed, OK: $tpl_ok"
}

# --- doctor ---

do_doctor() {
  require_jq
  local errors=0 warnings=0

  if [ ! -f "$MANIFEST" ]; then
    echo "No manifest found at $MANIFEST"
    echo "Run 'skills-deploy install' to create one."
    return
  fi

  local manifest
  manifest=$(cat "$MANIFEST")
  local source
  source=$(echo "$manifest" | jq -r '.source // ""')

  echo "=== skills-deploy doctor ==="
  echo "Source: $source"
  echo "Manifest: $MANIFEST"

  # Collection version check
  local installed_cv
  installed_cv=$(echo "$manifest" | jq -r '.collection_version // "unknown"')
  echo "Collection version (installed): $installed_cv"
  if [ -n "$source" ] && [ -f "$source/VERSION" ]; then
    local current_cv
    current_cv=$(tr -d '[:space:]' < "$source/VERSION")
    echo "Collection version (current):   $current_cv"
    if [ "$installed_cv" = "$current_cv" ]; then
      echo "  OK: up to date"
    elif [ "$installed_cv" = "unknown" ]; then
      echo "  WARN: installed before collection versioning. Run 'skills-deploy install' to update."
      warnings=$((warnings + 1))
    else
      echo "  WARN: installed version ($installed_cv) differs from current ($current_cv)."
      echo "  Fix: run 'skills-deploy install' to update, or 'cd $source && git pull' first."
      warnings=$((warnings + 1))
    fi
  elif [ -n "$source" ] && [ ! -d "$source" ]; then
    echo "  FAIL: source path '$source' no longer exists. Re-run 'skills-deploy install' from a valid clone."
    errors=$((errors + 1))
  fi

  # Update-check cache surface (skills-update-check state).
  local cache_file="${SKILLS_TEMPLATES_CACHE:-$HOME/.claude/.skills-templates-update.json}"
  if [ -f "$cache_file" ]; then
    local cache_local cache_remote cache_checked cache_snooze cache_skip
    cache_local=$(jq -r '.local_version // empty' "$cache_file" 2>/dev/null || echo "")
    cache_remote=$(jq -r '.remote_version // empty' "$cache_file" 2>/dev/null || echo "")
    cache_checked=$(jq -r '.checked_at // empty' "$cache_file" 2>/dev/null || echo "")
    cache_snooze=$(jq -r '.snooze_until // empty' "$cache_file" 2>/dev/null || echo "")
    cache_skip=$(jq -r '.skip_version // empty' "$cache_file" 2>/dev/null || echo "")
    echo "Update check:"
    if [ -n "$cache_checked" ]; then
      # Portable date formatting: try BSD then GNU.
      local checked_str
      checked_str=$(date -r "$cache_checked" 2>/dev/null || date -d "@$cache_checked" 2>/dev/null || echo "$cache_checked")
      echo "  Last check: $checked_str"
    else
      echo "  Last check: (never)"
    fi
    [ -n "$cache_local" ] && echo "  Cached local:  $cache_local"
    [ -n "$cache_remote" ] && echo "  Cached remote: $cache_remote"
    if [ -n "$cache_snooze" ]; then
      local now_ts
      now_ts=$(date +%s)
      if [ "$now_ts" -lt "$cache_snooze" ] 2>/dev/null; then
        local snooze_str
        snooze_str=$(date -r "$cache_snooze" 2>/dev/null || date -d "@$cache_snooze" 2>/dev/null || echo "$cache_snooze")
        echo "  Snoozed until: $snooze_str"
      fi
    fi
    [ -n "$cache_skip" ] && echo "  Skipping version: $cache_skip"
  else
    echo "Update check: (never run — runs on next skill invocation)"
  fi
  echo ""

  # Check each installed skill
  for name in $(echo "$manifest" | jq -r '.skills // {} | keys[]'); do
    # Source dir is catalog-driven (F000006): read manifest .skills[$n].path,
    # then dirname it. Falls back to skills/{name}/ for older installs.
    local manifest_path
    manifest_path=$(echo "$manifest" | jq -r --arg n "$name" '.skills[$n].path // ""')
    local src
    if [ -n "$manifest_path" ]; then
      src="$source/$(dirname "$manifest_path")"
    else
      src="$source/skills/$name"
    fi
    local target_dir="$SKILLS_TARGET/$name"
    local skill_md="$target_dir/SKILL.md"
    local _label
    _label="OK: $name"

    # Templates-only entries have no target directory
    if echo "$manifest" | jq -e --arg n "$name" '.skills[$n].templates_only' >/dev/null 2>&1; then
      echo "  OK: $name (templates-only)"
      continue
    fi

    # Branch on recorded install_kind (S000079); absent field → "symlink"
    # (back-compat for installs predating the field).
    local dr_kind
    dr_kind=$(echo "$manifest" | jq -r --arg n "$name" '.skills[$n].install_kind // "symlink"')

    if [ "$dr_kind" = "copy" ]; then
      # Copy-mode: verify each recorded source_checksums entry by re-hashing the
      # installed regular file; mismatch or missing → FAIL (mirrors the template
      # checksum FAIL below). Subdir contents are presence-checked, not deep-hashed.
      if [ ! -d "$target_dir" ]; then
        echo "  FAIL: $name — target directory missing"
        errors=$((errors + 1))
      else
        local copy_ok=true
        while IFS=$'\t' read -r cf csum; do
          [ -n "$cf" ] || continue
          local cfile="$target_dir/$cf"
          if [ ! -f "$cfile" ]; then
            echo "  FAIL: $name/$cf — file missing (copy-mode)"
            errors=$((errors + 1))
            copy_ok=false
          else
            local cactual
            cactual=$(file_checksum "$cfile")
            if [ "$csum" != "unknown" ] && [ -n "$csum" ] && [ "$cactual" != "$csum" ]; then
              echo "  FAIL: $name/$cf — content differs from source (copy-mode drift)"
              errors=$((errors + 1))
              copy_ok=false
            fi
          fi
        done < <(echo "$manifest" | jq -r --arg n "$name" '.skills[$n].source_checksums // {} | to_entries[] | .key + "\t" + .value')
        # Subdir presence-check (not deep-hashed) when source is available.
        if [ -d "$src" ]; then
          for sd in "$src"/*/; do
            [ -d "$sd" ] || continue
            local sdname
            sdname=$(basename "$sd")
            if [ ! -d "$target_dir/$sdname" ]; then
              echo "  FAIL: $name/$sdname — subdirectory missing (copy-mode)"
              errors=$((errors + 1))
              copy_ok=false
            fi
          done
        fi
        if [ "$copy_ok" = true ]; then
          echo "  $_label"
        fi
      fi
      continue
    fi

    if [ ! -d "$target_dir" ]; then
      echo "  FAIL: $name — target directory missing"
      errors=$((errors + 1))
    elif [ ! -L "$skill_md" ]; then
      echo "  WARN: $name — SKILL.md is not a symlink"
      warnings=$((warnings + 1))
    elif [ ! -e "$skill_md" ]; then
      echo "  FAIL: $name — broken symlink"
      errors=$((errors + 1))
    elif [ ! -d "$src" ]; then
      echo "  WARN: $name — source directory missing in repo"
      warnings=$((warnings + 1))
    else
      # Check subdirectory symlinks
      local subdir_ok=true
      for sd in "$src"/*/; do
        [ -d "$sd" ] || continue
        local sdname
        sdname=$(basename "$sd")
        local sdtarget="$target_dir/$sdname"
        if [ ! -e "$sdtarget" ]; then
          echo "  FAIL: $name/$sdname — subdirectory missing"
          errors=$((errors + 1))
          subdir_ok=false
        elif [ -L "$sdtarget" ] && [ ! -e "$sdtarget" ]; then
          echo "  FAIL: $name/$sdname — broken symlink"
          errors=$((errors + 1))
          subdir_ok=false
        fi
      done
      if [ "$subdir_ok" = true ]; then
        echo "  $_label"
      fi
    fi
  done

  # Check for orphans (symlinks to our repo not in manifest)
  echo ""
  for d in "$SKILLS_TARGET"/*/; do
    [ -d "$d" ] || continue
    local name
    name=$(basename "$d")
    local skill_md="$d/SKILL.md"
    if [ -L "$skill_md" ]; then
      local link
      link=$(readlink "$skill_md" 2>/dev/null || true)
      if [[ "$link" == "$source"/* ]] || [[ "$link" == "$REPO_ROOT"/* ]]; then
        if ! echo "$manifest" | jq -e --arg n "$name" '.skills[$n]' >/dev/null 2>&1; then
          echo "  ORPHAN: $name — symlinks to our repo but not in manifest"
          warnings=$((warnings + 1))
        fi
      fi
    fi
  done

  # Check templates
  local tpl_count
  tpl_count=$(echo "$manifest" | jq '.templates // {} | length')
  if [ "$tpl_count" -gt 0 ]; then
    echo "--- Templates ---"
    for tpl in $(echo "$manifest" | jq -r '.templates // {} | keys[]'); do
      local tpl_file="$TEMPLATES_TARGET/$tpl"
      if [ ! -f "$tpl_file" ]; then
        echo "  FAIL: $tpl — file missing at $tpl_file (run 'skills-deploy install' to restore)"
        errors=$((errors + 1))
      else
        local expected actual
        expected=$(echo "$manifest" | jq -r --arg t "$tpl" '.templates[$t].source_checksum // ""')
        actual=$(file_checksum "$tpl_file")
        if [ -n "$expected" ] && [ "$expected" != "$actual" ] && [ "$expected" != "unknown" ]; then
          echo "  WARN: $tpl — content differs from source (local changes or outdated)"
          warnings=$((warnings + 1))
        else
          echo "  OK: $tpl"
        fi
        # Line-ending drift (D000040 bucket c) — checked independently of the
        # checksum: the committed content is LF (.gitattributes eol=lf), so a
        # deployed copy with CR bytes is always Windows drift. It is
        # checksum-invisible when a CRLF install recorded the CRLF sum too, so the
        # comparison above can pass while the copy is still CRLF. Re-copy from an
        # LF checkout to clear it.
        if [ -n "$(tr -cd '\r' < "$tpl_file" 2>/dev/null)" ]; then
          echo "  WARN: $tpl — deployed copy has CRLF line endings (Windows drift; re-run 'skills-deploy install --overwrite' from an LF checkout)"
          warnings=$((warnings + 1))
        fi
      fi

      # Check for orphaned owners
      for owner in $(echo "$manifest" | jq -r --arg t "$tpl" '.templates[$t].owners // [] | .[]'); do
        if ! echo "$manifest" | jq -e --arg n "$owner" '.skills[$n]' >/dev/null 2>&1; then
          echo "  WARN: $tpl — owner '$owner' is not an installed skill (orphaned)"
          warnings=$((warnings + 1))
        fi
      done
    done

    # Check for catalog templates not in manifest (for installed skills)
    for name in $(echo "$manifest" | jq -r '.skills // {} | keys[]'); do
      for tpl in $(skill_templates "$name"); do
        if ! echo "$manifest" | jq -e --arg t "$tpl" '.templates[$t]' >/dev/null 2>&1; then
          echo "  WARN: $tpl — declared by $name but not deployed (run 'skills-deploy install' to deploy)"
          warnings=$((warnings + 1))
        fi
      done
    done
    echo ""
  fi

  # Check deployed rules
  if [ -d "$RULES_SRC" ]; then
    echo "--- Rules ---"
    local rules_ok=0 rules_drift=0 rules_missing=0
    for rule_file in "$RULES_SRC"/*.md; do
      [ -f "$rule_file" ] || continue
      local rule_name
      rule_name=$(basename "$rule_file")
      case "$rule_name" in README.md|NOTES.md|DEVELOPMENT.md|CHANGELOG.md) continue ;; esac
      local rule_dst="$RULES_TARGET/$rule_name"
      if [ ! -f "$rule_dst" ]; then
        echo "  MISSING: $rule_name — not deployed (run 'skills-deploy install' to deploy)"
        errors=$((errors + 1))
        rules_missing=$((rules_missing + 1))
      else
        local src_sum dst_sum
        src_sum=$(file_checksum "$rule_file")
        dst_sum=$(file_checksum "$rule_dst")
        if [ "$src_sum" = "$dst_sum" ]; then
          echo "  OK: $rule_name"
          rules_ok=$((rules_ok + 1))
        else
          echo "  WARN: $rule_name — deployed copy differs from source (run 'skills-deploy install' to sync)"
          warnings=$((warnings + 1))
          rules_drift=$((rules_drift + 1))
        fi
      fi
    done
    echo ""
  fi

  # Check deployed shared scripts (_cj-shared/scripts/). Mirrors the Templates +
  # Rules sections: report ORPHAN (deployed + tracked but no source counterpart —
  # the prune target), FAIL (manifest-tracked but missing on disk), WARN (content
  # drift), else OK. Keyed off the manifest `.shared_scripts` (basenames, no
  # spaces), so the simple `for k in $(jq ...)` idiom is safe.
  local shared_count
  shared_count=$(echo "$manifest" | jq '.shared_scripts // {} | length')
  if [ "$shared_count" -gt 0 ]; then
    echo "--- Shared scripts ---"
    for k in $(echo "$manifest" | jq -r '.shared_scripts // {} | keys[]'); do
      local shared_target="$SHARED_SCRIPTS_TARGET/$k"
      local shared_src="$SHARED_SCRIPTS_SRC/$k"
      if [ ! -f "$shared_src" ]; then
        echo "  ORPHAN: $k — deployed but no source counterpart (run 'skills-deploy install' to prune)"
        warnings=$((warnings + 1))
      elif [ ! -f "$shared_target" ]; then
        echo "  FAIL: $k — file missing at $shared_target (run 'skills-deploy install' to restore)"
        errors=$((errors + 1))
      else
        local shared_expected shared_actual
        shared_expected=$(echo "$manifest" | jq -r --arg t "$k" '.shared_scripts[$t].source_checksum // ""')
        shared_actual=$(file_checksum "$shared_target")
        if [ -n "$shared_expected" ] && [ "$shared_expected" != "$shared_actual" ] && [ "$shared_expected" != "unknown" ]; then
          echo "  WARN: $k — content differs from source (local changes or outdated)"
          warnings=$((warnings + 1))
        else
          echo "  OK: $k"
        fi
      fi
    done
    echo ""
  fi

  echo ""
  local skills_count
  skills_count=$(echo "$manifest" | jq '.skills // {} | length')
  if [ "$errors" -eq 0 ] && [ "$warnings" -eq 0 ]; then
    echo "Health: OK ($skills_count skills, $tpl_count templates installed)"
  else
    echo "Health: $errors errors, $warnings warnings ($skills_count skills, $tpl_count templates)"
  fi
}

# --- main ---

case "${1:-}" in
  install) shift; do_install "$@" ;;
  remove)  shift; do_remove "$@" ;;
  relink)  do_relink ;;
  doctor)  do_doctor ;;
  bundle-status) do_bundle_status ;;
  seed-contracts) shift; do_seed_contracts "$@" ;;
  install-contract-gate) shift; do_install_contract_gate "$@" ;;
  *)
    echo "Usage: skills-deploy <install|remove|relink|doctor|bundle-status|seed-contracts|install-contract-gate> [options]"
    echo ""
    echo "Commands:"
    echo "  install [skill...] [--no-overwrite]"
    echo "                                    Install skills + templates (all if none specified)."
    echo "                                    Drifted templates and rules are overwritten by default;"
    echo "                                    pass --no-overwrite to preserve deployed copies that differ"
    echo "                                    from source. (--overwrite is accepted as a no-op for"
    echo "                                    backwards compatibility with pre-v1.6 callers.)"
    echo "  remove <skill...>                 Remove skills + templates (--all for all, --force to skip dep check)"
    echo "  relink                            Repair broken/missing symlinks + templates"
    echo "  doctor                            Check installation health (skills + templates)"
    echo "  install --bundle                  Install == clone: ensure a managed git checkout"
    echo "                                    (~/.claude/skills/cj-workbench) + symlink the flat /CJ_*"
    echo "                                    INTO it; develop in place. Opt-in; legacy install untouched."
    echo "  bundle-status                     Show the develop-in-place bundle's path/branch/origin/tree"
    echo "  seed-contracts [--repo <path>]    Force-seed the three contracts (spec/doc-spec.md,"
    echo "                                    spec/test-spec.md, spec/workflow-spec.md) into a CONSUMER repo"
    echo "                                    (cwd, or --repo). Idempotent (present⇒skip), corruption-guarded"
    echo "                                    (--seed → non-empty + --validate-clean → mv). The workbench"
    echo "                                    self-repo is skipped (data-loss guard); a non-git dir is a no-op."
    echo "  install-contract-gate [--repo <path>] [--remove]"
    echo "                                    Install (or --remove) the cj-contract-gate enforcement on a"
    echo "                                    CONSUMER repo (cwd, or --repo): the pre-commit hook PLUS the"
    echo "                                    vendored gate engines in .cj-contract/ and a dropped CI workflow"
    echo "                                    (.github/workflows/cj-contract-gate.yml) that runs the vendored"
    echo "                                    gate on a bare runner with no ~/.claude. A hard finding blocks"
    echo "                                    the commit / reds the PR. Guarded: workbench-self / custom"
    echo "                                    core.hooksPath (husky) are skipped; a non-workbench hook and a"
    echo "                                    hand-authored workflow are left untouched. --remove reverses the"
    echo "                                    hook + .cj-contract/ + workflow, but ONLY sentinel-marked copies."
    exit 1
    ;;
esac
