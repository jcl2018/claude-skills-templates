#!/usr/bin/env bash
# skills-update-check — passive update detector for claude-skills-templates consumers.
#
# Default action (F000081/WS3 — checkout-independent): read manifest + cache, and
# once per 24h read the max published v<X.Y.Z> tag from the upstream repo via
# `git ls-remote --tags <upstream_url>`. Compare manifest.collection_version (LOCAL)
# vs that remote tag; print SKILLS_UPGRADE_AVAILABLE if the remote is newer. This
# works on ANY machine — a remote host or a consumer/foreign repo with NO live
# workbench `.git` checkout — because the remote read is an anonymous ls-remote
# against the published repo, not a fetch into a local clone. The old `.source`/.git
# gate is GONE; `.source`, when present, is used only for the richer git-pull upgrade
# ACTION (in the skill preamble) + origin-URL pinning. Print SKILLS_JUST_UPGRADED
# once after a successful skills-deploy install --from-upgrade. All errors silenced —
# ls-remote unreachable / no v-tags → silent (never a false nudge); never blocks a
# skill workflow.
#
# Subcommands let skill bodies write cache state without writing JSON themselves:
#   --snooze [hours]            (default 24)
#   --skip <version>
#   --prompted <session_id>
#   --should-prompt <session_id>  (exit 0 = prompt; exit 1 = suppress within 10 min)
#
# State files:
#   manifest:  $HOME/.claude/.skills-templates.json (written by skills-deploy install)
#   cache:     $HOME/.claude/.skills-templates-update.json
#   marker:    $HOME/.claude/.skills-templates-just-upgraded
#
# Test seams (hermetic, no real network):
#   SKILLS_TEMPLATES_MANIFEST   override the manifest path
#   SKILLS_UPDATE_REMOTE_URL    the remote URL to ls-remote (bypasses upstream_url);
#                               point it at a local bare repo / a PATH-stubbed git
#   SKILLS_UPDATE_STATE_DIR     repoint the cache + marker into a throwaway dir
#
# Reuses version_gte from scripts/lib.sh (sourced if available).

set -euo pipefail

MANIFEST="${SKILLS_TEMPLATES_MANIFEST:-$HOME/.claude/.skills-templates.json}"
# SKILLS_UPDATE_STATE_DIR (F000081/WS3) — a hermetic test override that repoints the
# cache + marker into a throwaway dir so the unit test never touches ~/.claude state.
# Explicit SKILLS_TEMPLATES_CACHE / SKILLS_TEMPLATES_MARKER still win (back-compat).
_STATE_DIR="${SKILLS_UPDATE_STATE_DIR:-$HOME/.claude}"
CACHE="${SKILLS_TEMPLATES_CACHE:-$_STATE_DIR/.skills-templates-update.json}"
MARKER="${SKILLS_TEMPLATES_MARKER:-$_STATE_DIR/.skills-templates-just-upgraded}"

# Strip CRLF from jq output on Windows (jq.exe writes \r\n). No-op on Unix.
jq() { command jq "$@" | tr -d '\r'; }

# Source version_gte from lib.sh if reachable. Otherwise fall back to inline.
_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$_SCRIPT_DIR/lib.sh" ]; then
  # lib.sh has its own `set -euo pipefail`, jq() wrapper, and runs init() lazily.
  # We only need version_gte; sourcing the whole file is fine — REPO_ROOT etc.
  # exports are harmless in this context.
  # shellcheck disable=SC1091
  . "$_SCRIPT_DIR/lib.sh" 2>/dev/null || true
fi

# Fallback if lib.sh wasn't loadable.
if ! command -v version_gte >/dev/null 2>&1; then
  version_gte() {
    local a1 a2 a3 b1 b2 b3
    IFS='.' read -r a1 a2 a3 <<< "$1"
    IFS='.' read -r b1 b2 b3 <<< "$2"
    if [ "${a1:-0}" -gt "${b1:-0}" ]; then return 0; fi
    if [ "${a1:-0}" -lt "${b1:-0}" ]; then return 1; fi
    if [ "${a2:-0}" -gt "${b2:-0}" ]; then return 0; fi
    if [ "${a2:-0}" -lt "${b2:-0}" ]; then return 1; fi
    if [ "${a3:-0}" -gt "${b3:-0}" ]; then return 0; fi
    if [ "${a3:-0}" -lt "${b3:-0}" ]; then return 1; fi
    return 0
  }
fi

# --- helpers ---

cache_read() {
  if [ ! -f "$CACHE" ]; then
    echo '{}'
    return 0
  fi
  # Self-heal corrupt cache: if jq can't parse it, return empty object so
  # subcommands don't wedge under set -euo pipefail. Codex finding #6.
  local raw
  raw=$(cat "$CACHE" 2>/dev/null) || { echo '{}'; return 0; }
  if printf '%s' "$raw" | jq -e . >/dev/null 2>&1; then
    printf '%s' "$raw"
  else
    echo '{}'
  fi
}

# Atomic write: mktemp on the same filesystem as the target, then mv.
cache_write() {
  local payload tmp
  payload=$(cat)
  tmp=$(mktemp "$CACHE.tmp.XXXXXX") || return 1
  printf '%s\n' "$payload" > "$tmp"
  mv "$tmp" "$CACHE"
}

manifest_field() {
  local field="$1"
  [ -f "$MANIFEST" ] || { echo ""; return 0; }
  jq -r --arg k "$field" '.[$k] // empty' "$MANIFEST" 2>/dev/null || echo ""
}

# Validate that a string looks like a 3-digit semver. The repo's truth is 3-digit
# (per validate_version_string in lib.sh and skills-deploy --from-upgrade regex).
# Accepting 4-digit here would be unsafe because version_gte only compares 3
# components — a 4-digit pair like 1.2.3.9 vs 1.2.3.10 would silently compare equal.
is_semver() {
  printf '%s' "$1" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'
}

# Normalize an upstream URL to a form `git ls-remote` can read anonymously.
# ssh-form (git@github.com:OWNER/REPO.git) → https (https://github.com/OWNER/REPO.git)
# so a consumer/remote install with no ssh key can still read public tags. Any URL
# already https/http/git:// (or a local path) passes through unchanged — git handles
# ssh + https + non-GitHub hosts, so we only rewrite the one form anonymous reads need.
normalize_upstream_url() {
  local url="$1"
  case "$url" in
    git@*:*)
      # git@host:owner/repo(.git) → https://host/owner/repo(.git)
      local host_path="${url#git@}"          # host:owner/repo.git
      local host="${host_path%%:*}"          # host
      local path="${host_path#*:}"           # owner/repo.git
      printf 'https://%s/%s' "$host" "$path"
      ;;
    ssh://git@*)
      # ssh://git@host/owner/repo(.git) → https://host/owner/repo(.git)
      printf 'https://%s' "${url#ssh://git@}"
      ;;
    *)
      printf '%s' "$url"
      ;;
  esac
}

# Read the max published v<X.Y.Z> release tag from a remote via `git ls-remote`.
# Checkout-INDEPENDENT (F000081/WS3): no local .git checkout required — anonymous
# ls-remote against the published repo. Prints the bare X.Y.Z (no `v`) of the highest
# 3-digit v-tag, or nothing (fail-soft) when the remote is unreachable / has no v-tags.
# GIT_TERMINAL_PROMPT=0 + GIT_ASKPASS=true + a batch-mode ssh + a short timeout keep it
# from ever hanging a skill preamble on an auth or network stall.
remote_max_tag() {
  local url="$1"
  [ -n "$url" ] || return 0
  local raw
  # ls-remote --tags <url> 'v*' → lines: "<sha>\trefs/tags/vX.Y.Z". Strip to the
  # X.Y.Z, keep only 3-digit semver tags, sort version-descending, take the top.
  raw=$(GIT_TERMINAL_PROMPT=0 GIT_ASKPASS=true \
        GIT_SSH_COMMAND='ssh -o BatchMode=yes -o ConnectTimeout=5' \
        git ls-remote --tags "$url" 'v*' 2>/dev/null | tr -d '\r') || return 0
  [ -n "$raw" ] || return 0
  # For each line: take the ref (2nd field), drop a peeled-tag `^{}` suffix, keep only
  # refs/tags/v<3-digit-semver>, strip the `refs/tags/v` prefix, then sort semver-desc.
  # The `|| true` neutralizes grep's exit 1 when NO v-tag matches (a legit
  # "no release tags" case) so this never trips the caller's `set -e` — an empty
  # print is the fail-soft signal, not an error. Capture then echo so the function
  # itself always returns 0.
  local max
  max=$(printf '%s\n' "$raw" \
    | awk '{print $2}' \
    | sed 's/\^{}$//' \
    | grep -E '^refs/tags/v[0-9]+\.[0-9]+\.[0-9]+$' \
    | sed 's#^refs/tags/v##' \
    | sort -t. -k1,1n -k2,2n -k3,3n \
    | tail -1) || true
  printf '%s' "$max"
  return 0
}

now_epoch() { date +%s; }

# --- subcommands ---

cmd_snooze() {
  local hours="${1:-24}"
  # Guard: numeric input only.
  case "$hours" in
    ''|*[!0-9]*) hours=24 ;;
  esac
  local until_ts
  until_ts=$(( $(now_epoch) + hours * 3600 ))
  cache_read | jq --argjson u "$until_ts" '. + {snooze_until: $u}' | cache_write
}

cmd_skip() {
  local version="${1:-}"
  if [ -z "$version" ]; then
    echo "skills-update-check: --skip requires <version>" >&2
    exit 2
  fi
  if ! is_semver "$version"; then
    echo "skills-update-check: --skip <version> must be semver (got '$version')" >&2
    exit 2
  fi
  cache_read | jq --arg v "$version" '. + {skip_version: $v}' | cache_write
}

cmd_prompted() {
  local session="${1:-}"
  if [ -z "$session" ]; then
    echo "skills-update-check: --prompted requires <session_id>" >&2
    exit 2
  fi
  local now_ts
  now_ts=$(now_epoch)
  cache_read | jq --arg s "$session" --argjson t "$now_ts" \
    '. + {prompted_session: $s, prompted_at: $t}' | cache_write
}

# Exit 0 = prompt the user (fresh session or window expired).
# Exit 1 = suppress (already prompted in this session within last 10 min).
cmd_should_prompt() {
  local session="${1:-}"
  if [ -z "$session" ]; then
    echo "skills-update-check: --should-prompt requires <session_id>" >&2
    exit 2
  fi
  local cache prompted_session prompted_at now_ts elapsed
  cache=$(cache_read)
  prompted_session=$(printf '%s' "$cache" | jq -r '.prompted_session // empty' 2>/dev/null || echo "")
  prompted_at=$(printf '%s' "$cache" | jq -r '.prompted_at // empty' 2>/dev/null || echo "")
  if [ -z "$prompted_session" ] || [ -z "$prompted_at" ]; then
    exit 0
  fi
  if [ "$prompted_session" != "$session" ]; then
    exit 0
  fi
  # Guard: non-numeric prompted_at would crash arithmetic under set -euo pipefail.
  case "$prompted_at" in ''|*[!0-9]*) exit 0 ;; esac
  now_ts=$(now_epoch)
  elapsed=$(( now_ts - prompted_at ))
  # 10-minute debounce window.
  if [ "$elapsed" -lt 600 ]; then
    exit 1
  fi
  exit 0
}

# --- default action: the check ---

emit_just_upgraded() {
  # Read marker into a var FIRST, then unlink, then emit. Tolerates concurrent
  # consumption: if cat fails (another process unlinked first), we silently skip.
  if [ -f "$MARKER" ]; then
    local payload
    payload=$(cat "$MARKER" 2>/dev/null || true)
    rm -f "$MARKER" 2>/dev/null || true
    if [ -n "$payload" ]; then
      # Format is single line: "<from> <to>"
      local from to
      read -r from to <<< "$payload"
      if [ -n "$from" ] && [ -n "$to" ]; then
        echo "SKILLS_JUST_UPGRADED $from $to"
      fi
    fi
  fi
}

cmd_default() {
  # Always check the marker — independent of the upgrade-available banner.
  emit_just_upgraded

  # Manifest gate: silent exit if not installed via skills-deploy.
  [ -f "$MANIFEST" ] || exit 0
  local source_path local_version expected_upstream
  source_path=$(manifest_field "source")
  local_version=$(manifest_field "collection_version")
  expected_upstream=$(manifest_field "upstream_url")
  # Checkout-INDEPENDENT (F000081/WS3): the ONLY hard requirement now is a local
  # version to compare against. The old `.source` + `[ -d .source/.git ]` gate was
  # removed — a remote machine / consumer repo with no live workbench checkout still
  # gets a staleness nudge, because the remote read below is an anonymous
  # `git ls-remote` against the published upstream, not a fetch into a local clone.
  # `.source` is now used ONLY for the richer git-pull upgrade ACTION + origin-pinning
  # (both best-effort, below); its absence never suppresses the banner.
  [ -n "$local_version" ] || exit 0

  # Resolve the remote URL to read published tags from. A test seam
  # (SKILLS_UPDATE_REMOTE_URL) wins for hermetic no-network runs; otherwise the
  # manifest upstream_url, normalized ssh→https so anonymous public reads work.
  local remote_url
  if [ -n "${SKILLS_UPDATE_REMOTE_URL:-}" ]; then
    remote_url="$SKILLS_UPDATE_REMOTE_URL"
  else
    remote_url=$(normalize_upstream_url "$expected_upstream")
  fi
  # Backward-compat fallback (F000081/WS3): a pre-upstream_url (legacy) manifest
  # carries no upstream_url, but when a live .source checkout is present we can still
  # resolve a remote to read tags from via its origin URL. Keeps legacy manifests
  # detecting updates; a remote/consumer install with neither an upstream_url nor a
  # .source checkout simply can't resolve a remote and exits silent below.
  if [ -z "$remote_url" ] && [ -n "$source_path" ] && [ -d "$source_path/.git" ]; then
    remote_url=$(normalize_upstream_url "$(git -C "$source_path" remote get-url origin 2>/dev/null || true)")
  fi
  [ -n "$remote_url" ] || exit 0

  # Origin URL pinning (T000031) — best-effort, and ONLY when a live .source git
  # checkout exists. If the manifest recorded an upstream_url and .source's current
  # origin has been redirected since install, suppress the banner + warn (someone —
  # legit or attacker — repointed origin). A consumer/remote install with no .source
  # checkout simply skips this pin (nothing local to compare) and reads the remote
  # directly. Pre-T000031 manifests have no upstream_url; treat empty as "not pinned".
  if [ -n "$expected_upstream" ] && [ -n "$source_path" ] && [ -d "$source_path/.git" ]; then
    local current_upstream
    current_upstream=$(git -C "$source_path" remote get-url origin 2>/dev/null || true)
    if [ -n "$current_upstream" ] && [ "$current_upstream" != "$expected_upstream" ]; then
      echo "WARN: skills-update-check: origin URL mismatch — expected '$expected_upstream', got '$current_upstream'. Suppressing upgrade banner; re-run 'skills-deploy install' from a trusted clone to re-pin." >&2
      exit 0
    fi
  fi

  # Cache + snooze + skip gates.
  local cache snooze_until skip_version checked_at remote_version
  cache=$(cache_read)
  snooze_until=$(printf '%s' "$cache" | jq -r '.snooze_until // empty' 2>/dev/null || echo "")
  skip_version=$(printf '%s' "$cache" | jq -r '.skip_version // empty' 2>/dev/null || echo "")
  checked_at=$(printf '%s' "$cache" | jq -r '.checked_at // empty' 2>/dev/null || echo "")
  remote_version=$(printf '%s' "$cache" | jq -r '.remote_version // empty' 2>/dev/null || echo "")

  local now_ts
  now_ts=$(now_epoch)

  # Guard: non-numeric snooze_until would let the banner emit when it shouldn't.
  case "$snooze_until" in ''|*[!0-9]*) snooze_until="" ;; esac
  if [ -n "$snooze_until" ] && [ "$now_ts" -lt "$snooze_until" ]; then
    exit 0
  fi

  # Decide whether to refetch. 24h TTL.
  local need_fetch=1
  if [ -n "$checked_at" ] && [ -n "$remote_version" ]; then
    # Guard: non-numeric checked_at would crash arithmetic under set -euo pipefail.
    case "$checked_at" in ''|*[!0-9]*) checked_at="" ;; esac
    if [ -n "$checked_at" ]; then
      local age=$(( now_ts - checked_at ))
      if [ "$age" -ge 0 ] && [ "$age" -lt 86400 ]; then
        need_fetch=0
      fi
    fi
  fi

  if [ "$need_fetch" = "1" ]; then
    # Read the max published v<X.Y.Z> tag via `git ls-remote --tags` (checkout-
    # independent). On any failure (unreachable remote / no v-tags) remote_max_tag
    # prints nothing and we fall back to the stale cache; if the cache is also empty
    # we exit silent — never a false nudge. `v`-tag assumption: this reads the latest
    # release v-tag (collection v-tags are ratcheted by validate.sh Error check 8); a
    # consumer whose upstream_url repo doesn't tag releases fail-softs to silent.
    local fresh_remote=""
    fresh_remote=$(remote_max_tag "$remote_url")
    if [ -n "$fresh_remote" ] && is_semver "$fresh_remote"; then
      remote_version="$fresh_remote"
      cache_read | jq --argjson t "$now_ts" --arg lv "$local_version" --arg rv "$remote_version" \
        '. + {checked_at: $t, local_version: $lv, remote_version: $rv}' | cache_write
    fi
    # If the remote read failed AND cache had nothing, exit silent.
    if [ -z "$remote_version" ]; then
      exit 0
    fi
  fi

  # Comparison: emit banner if remote strictly newer AND not the skipped version.
  if ! is_semver "$local_version" || ! is_semver "$remote_version"; then
    exit 0
  fi
  if [ "$remote_version" = "$skip_version" ]; then
    exit 0
  fi
  if version_gte "$remote_version" "$local_version" && [ "$remote_version" != "$local_version" ]; then
    echo "SKILLS_UPGRADE_AVAILABLE $local_version $remote_version"
  fi
}

# --- entry point ---

main() {
  if [ "$#" -eq 0 ]; then
    cmd_default
    exit 0
  fi

  local cmd="$1"; shift
  case "$cmd" in
    --snooze) cmd_snooze "$@" ;;
    --skip) cmd_skip "$@" ;;
    --prompted) cmd_prompted "$@" ;;
    --should-prompt) cmd_should_prompt "$@" ;;
    --help|-h)
      cat <<'USAGE'
skills-update-check — passive update detector for claude-skills-templates consumers.

Usage:
  skills-update-check                       # default check, emits banner if upgrade available
  skills-update-check --snooze [hours]      # suppress for N hours (default 24)
  skills-update-check --skip <version>      # never nudge for this specific version
  skills-update-check --prompted <session>  # mark current session as prompted
  skills-update-check --should-prompt <session>  # exit 0 if prompt needed, exit 1 if suppressed
USAGE
      exit 0
      ;;
    *)
      echo "skills-update-check: unknown subcommand '$cmd'" >&2
      echo "  see --help" >&2
      exit 2
      ;;
  esac
}

main "$@"
