{
  "version": "1.0.0",
  "description": "Company work item type-to-artifact mapping. Read by validate.prompt.md (directory mode). Mirror of skills/company-workflow/company-artifact-manifests.json — kept in sync via scripts/validate.sh.",
  "types": {
    "feature": {
      "required": [
        {"artifact": "tracker", "template": "tracker-feature.md", "filename": "TRACKER.md"},
        {"artifact": "feature-summary", "template": "doc-feature-summary.md", "filename": "feature-summary.md"},
        {"artifact": "milestones", "template": "doc-milestones.md", "filename": "milestones.md"}
      ]
    },
    "defect": {
      "required": [
        {"artifact": "tracker", "template": "tracker-defect.md", "filename": "TRACKER.md"},
        {"artifact": "rca", "template": "doc-RCA.md", "filename": "RCA.md"},
        {"artifact": "test-plan", "template": "doc-test-plan.md", "filename": "test-plan.md"},
        {"artifact": "pr-description", "template": "doc-pr-description-defect.md", "filename": "PR-DESCRIPTION.md"}
      ]
    },
    "task": {
      "required": [
        {"artifact": "tracker", "template": "tracker-task.md", "filename": "TRACKER.md"},
        {"artifact": "test-plan", "template": "doc-test-plan.md", "filename": "test-plan.md"},
        {"artifact": "pr-description", "template": "doc-pr-description-task.md", "filename": "PR-DESCRIPTION.md"}
      ]
    },
    "user-story": {
      "required": [
        {"artifact": "tracker", "template": "tracker-user-story.md", "filename": "TRACKER.md"},
        {"artifact": "prd", "template": "doc-PRD.md", "filename": "PRD.md"},
        {"artifact": "architecture", "template": "doc-ARCHITECTURE.md", "filename": "ARCHITECTURE.md"},
        {"artifact": "test-spec", "template": "doc-TEST-SPEC.md", "filename": "TEST-SPEC.md"},
        {"artifact": "milestones", "template": "doc-milestones.md", "filename": "milestones.md"}
      ]
    },
    "review": {
      "required": [
        {"artifact": "tracker", "template": "tracker-review.md", "filename": "TRACKER.md"},
        {"artifact": "review-notes", "template": "doc-review-notes.md", "filename": "review-notes.md"}
      ]
    }
  }
}
